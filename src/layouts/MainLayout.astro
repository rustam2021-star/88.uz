---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import SeoHead from "../components/SeoHead.astro";
import { site } from "../lib/catalog";

const {
  title = site.title,
  description = site.description,
  canonical = "/",
  ogType = "website",
  schema = []
} = Astro.props;
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;700&family=Space+Grotesk:wght@500;600;700&display=swap"
      rel="stylesheet"
    />
    <SeoHead
      title={title}
      description={description}
      canonical={canonical}
      ogType={ogType}
      schema={schema}
    />
  </head>
  <body>
    <a class="skip-link" href="#content">К содержимому</a>
    <Header />
    <main id="content">
      <slot />
    </main>
    <Footer />
  </body>
</html>

<style is:global>
  :root {
    color-scheme: light;
    --ink: #08111f;
    --muted: #5a6678;
    --line: #d7e0ea;
    --panel: #ffffff;
    --soft: #f4f7fb;
    --deep: #020617;
    --deep-2: #0b1220;
    --deep-3: #111827;
    --accent: #0ea5e9;
    --accent-2: #22c55e;
    --accent-3: #f59e0b;
    --danger: #dc2626;
    --ok: #0f8a5f;
    --warn: #9a5b07;
    --shadow: 0 22px 48px rgba(8, 17, 31, 0.14);
    --radius: 8px;
    font-family:
      "DM Sans", ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
      sans-serif;
  }

  * {
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    margin: 0;
    background: var(--soft);
    color: var(--ink);
    line-height: 1.55;
  }

  body::before {
    content: "";
    position: fixed;
    inset: 0;
    z-index: -1;
    pointer-events: none;
    background:
      linear-gradient(rgba(14, 165, 233, 0.05) 1px, transparent 1px),
      linear-gradient(90deg, rgba(14, 165, 233, 0.04) 1px, transparent 1px);
    background-size: 48px 48px;
    opacity: 0.7;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  a,
  button {
    touch-action: manipulation;
  }

  a:focus-visible,
  button:focus-visible {
    outline: 3px solid rgba(14, 165, 233, 0.75);
    outline-offset: 3px;
  }

  img {
    display: block;
    max-width: 100%;
  }

  main {
    min-height: 60vh;
  }

  .skip-link {
    position: fixed;
    top: 12px;
    left: 12px;
    z-index: 100;
    transform: translateY(-140%);
    padding: 10px 14px;
    border-radius: var(--radius);
    background: #fff;
    color: var(--deep);
    font-weight: 700;
    box-shadow: var(--shadow);
  }

  .skip-link:focus {
    transform: translateY(0);
  }

  .site-header,
  .site-footer,
  .section,
  .store-hero,
  .product-detail,
  .content-band,
  .page-title,
  .product-title {
    padding-inline: clamp(16px, 4vw, 64px);
  }

  .site-header {
    position: sticky;
    top: 0;
    z-index: 20;
    display: grid;
    grid-template-columns: auto minmax(0, 1fr) auto;
    gap: 24px;
    align-items: center;
    min-height: 76px;
    background: rgba(2, 6, 23, 0.92);
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    color: #fff;
    backdrop-filter: blur(16px);
  }

  .brand,
  .brand-logo,
  .brand-copy,
  .main-nav,
  .mobile-menu-head,
  .mobile-search-field,
  .product-meta,
  .actions,
  .stats,
  .chips,
  .footer-links,
  .breadcrumbs,
  .category-rail,
  .feature-strip,
  .hero-specs,
  .product-kpis {
    display: flex;
    align-items: center;
  }

  .brand {
    gap: 12px;
    min-width: 0;
  }

  .brand-logo {
    gap: 12px;
    min-width: 0;
    color: #fff;
  }

  .brand-logo-mark {
    flex: 0 0 auto;
    width: 126px;
    height: 48px;
    border-radius: 10px;
    filter: drop-shadow(0 10px 24px rgba(14, 165, 233, 0.2));
  }

  .brand-logo-text {
    display: flex;
    min-width: 0;
    flex-direction: column;
    align-items: flex-start;
    line-height: 1;
  }

  .brand-logo-name {
    color: #fff;
    font-size: 1.28rem;
    font-weight: 900;
  }

  .brand-logo-name span {
    color: #7dd3fc;
  }

  .brand-logo-tag {
    margin-top: 4px;
    color: #b7c4d6;
    font-size: 0.72rem;
    font-weight: 900;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .brand-copy {
    flex-direction: column;
    align-items: flex-start;
    line-height: 1.08;
  }

  .brand-copy strong,
  .brand-logo-name,
  h1,
  h2,
  h3,
  .price {
    font-family: "Space Grotesk", "DM Sans", sans-serif;
    letter-spacing: 0;
  }

  .brand-copy small,
  .brand-logo-tag,
  .eyebrow,
  .product-category,
  .breadcrumbs,
  .stock,
  .spec-label,
  .card-link,
  .microcopy {
    color: var(--muted);
    font-size: 0.9rem;
  }

  .site-header .brand-copy small,
  .site-header .brand-logo-tag,
  .site-header .main-nav a {
    color: #b7c4d6;
  }

  .main-nav {
    gap: 4px;
    overflow-x: auto;
    scrollbar-width: none;
    white-space: nowrap;
  }

  .main-nav::-webkit-scrollbar {
    display: none;
  }

  .main-nav a,
  .header-action,
  .button,
  .chip,
  .category-pill {
    min-height: 44px;
    border-radius: var(--radius);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition:
      background-color 180ms ease,
      border-color 180ms ease,
      color 180ms ease,
      transform 180ms ease;
  }

  .main-nav a {
    padding: 0 12px;
    font-size: 0.94rem;
  }

  .main-nav a:hover {
    background: rgba(255, 255, 255, 0.08);
    color: #fff;
  }

  .header-action,
  .button-primary {
    background: var(--accent);
    color: #fff;
  }

  .header-action {
    padding: 0 16px;
    font-weight: 800;
    box-shadow: 0 12px 28px rgba(14, 165, 233, 0.28);
  }

  .mobile-menu-toggle {
    display: none;
    position: relative;
    width: 44px;
    height: 44px;
    border: 1px solid rgba(255, 255, 255, 0.16);
    border-radius: var(--radius);
    background: rgba(255, 255, 255, 0.08);
    color: #fff;
    cursor: pointer;
    overflow: hidden;
    transition:
      background-color 180ms ease,
      border-color 180ms ease,
      box-shadow 180ms ease,
      transform 180ms ease;
  }

  .mobile-search-field svg {
    width: 22px;
    height: 22px;
    fill: none;
    stroke: currentColor;
    stroke-width: 2;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .mobile-menu-toggle span {
    position: absolute;
    left: 12px;
    width: 20px;
    height: 2px;
    border-radius: 999px;
    background: currentColor;
    transform-origin: center;
    transition:
      opacity 150ms ease,
      transform 230ms cubic-bezier(0.16, 1, 0.3, 1),
      width 180ms ease;
  }

  .mobile-menu-toggle span:nth-child(1) {
    transform: translateY(-6px);
  }

  .mobile-menu-toggle span:nth-child(2) {
    transform: translateY(0);
  }

  .mobile-menu-toggle span:nth-child(3) {
    transform: translateY(6px);
  }

  .mobile-menu-overlay,
  .mobile-menu {
    display: none;
  }

  .mobile-menu-actions {
    display: grid;
    gap: 10px;
  }

  .button {
    padding: 0 18px;
    border: 1px solid transparent;
    font-weight: 800;
  }

  .button:hover,
  .header-action:hover,
  .product-card:hover .card-link {
    transform: translateY(-1px);
  }

  .button-secondary {
    background: #fff;
    border-color: var(--line);
    color: var(--ink);
  }

  .button-ghost {
    background: rgba(255, 255, 255, 0.08);
    border-color: rgba(255, 255, 255, 0.16);
    color: #fff;
  }

  .store-hero {
    display: grid;
    grid-template-columns: minmax(0, 1.02fr) minmax(320px, 0.98fr);
    gap: clamp(28px, 5vw, 72px);
    align-items: center;
    min-height: 660px;
    padding-block: 58px 42px;
    color: #fff;
    background:
      linear-gradient(120deg, rgba(14, 165, 233, 0.16), transparent 36%),
      linear-gradient(180deg, var(--deep), var(--deep-2));
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    overflow: hidden;
  }

  .hero-copy {
    max-width: 830px;
  }

  .eyebrow {
    margin: 0 0 12px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 800;
  }

  .store-hero .eyebrow {
    color: #7dd3fc;
  }

  .store-hero h1,
  .page-title h1,
  .product-title h1 {
    margin: 0;
    max-width: 920px;
    line-height: 1.02;
    font-size: clamp(2.35rem, 6vw, 5.8rem);
  }

  .store-hero p,
  .page-title p,
  .product-title p {
    max-width: 760px;
    font-size: 1.08rem;
  }

  .store-hero p {
    color: #c6d3e1;
  }

  .actions {
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 28px;
  }

  .stats {
    gap: 10px;
    margin-top: 30px;
    flex-wrap: wrap;
  }

  .stat {
    min-width: 154px;
    padding: 14px 16px;
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: var(--radius);
    background: rgba(255, 255, 255, 0.06);
  }

  .stat strong {
    display: block;
    font-family: "Space Grotesk", sans-serif;
    font-size: 1.42rem;
  }

  .hero-visual {
    position: relative;
    min-height: 510px;
  }

  .hero-panel {
    position: relative;
    display: grid;
    gap: 14px;
    padding: 18px;
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: var(--radius);
    background:
      linear-gradient(rgba(255, 255, 255, 0.05) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.04) 1px, transparent 1px),
      rgba(255, 255, 255, 0.06);
    background-size: 36px 36px;
    box-shadow: 0 28px 80px rgba(0, 0, 0, 0.36);
  }

  .hero-device {
    display: grid;
    grid-template-columns: 1fr 0.72fr;
    gap: 14px;
    min-height: 420px;
  }

  .hero-product {
    position: relative;
    display: grid;
    place-items: center;
    overflow: hidden;
    border-radius: var(--radius);
    background: #f8fafc;
  }

  .hero-product img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    padding: 18px;
  }

  .hero-side {
    display: grid;
    gap: 14px;
  }

  .hero-mini {
    display: grid;
    grid-template-columns: 88px minmax(0, 1fr);
    gap: 12px;
    align-items: center;
    min-height: 126px;
    padding: 12px;
    border-radius: var(--radius);
    background: #fff;
    color: var(--ink);
  }

  .hero-mini img {
    width: 88px;
    height: 88px;
    object-fit: contain;
  }

  .hero-mini strong {
    display: block;
    line-height: 1.15;
  }

  .hero-mini span {
    color: var(--muted);
    font-size: 0.88rem;
  }

  .hero-specs {
    gap: 8px;
    flex-wrap: wrap;
  }

  .hero-specs span {
    padding: 8px 10px;
    border-radius: var(--radius);
    background: rgba(14, 165, 233, 0.13);
    color: #bae6fd;
    font-size: 0.9rem;
    font-weight: 700;
  }

  .section,
  .content-band {
    padding-block: 48px;
  }

  .section-heading {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 18px;
    margin-bottom: 22px;
  }

  .section-heading h2,
  .site-footer h2 {
    margin: 0;
  }

  .section-heading h2 {
    font-size: clamp(1.55rem, 3vw, 2.4rem);
  }

  .grid,
  .category-grid {
    display: grid;
    gap: 18px;
  }

  .grid {
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
  }

  .category-grid {
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
  }

  .category-card,
  .product-card,
  .faq-item,
  .spec-list,
  .contact-panel,
  .info-card {
    background: var(--panel);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    box-shadow: 0 14px 34px rgba(8, 17, 31, 0.07);
  }

  .category-card {
    position: relative;
    min-height: 168px;
    padding: 18px;
    overflow: hidden;
  }

  .category-card::after {
    content: "";
    position: absolute;
    right: 16px;
    bottom: 16px;
    width: 54px;
    height: 6px;
    border-radius: 999px;
    background: linear-gradient(90deg, var(--accent), var(--accent-2));
  }

  .category-card span {
    color: var(--accent);
    font-family: "Space Grotesk", sans-serif;
    font-weight: 800;
  }

  .category-card h3,
  .product-card h3 {
    margin: 8px 0;
    font-size: 1.12rem;
    line-height: 1.18;
  }

  .category-card p,
  .product-card p,
  .text-content p,
  .faq-item p,
  .contact-panel p {
    color: var(--muted);
    margin: 0;
  }

  .product-card {
    overflow: hidden;
    transition:
      transform 180ms ease,
      box-shadow 180ms ease,
      border-color 180ms ease;
  }

  .product-card:hover {
    transform: translateY(-3px);
    border-color: rgba(14, 165, 233, 0.42);
    box-shadow: var(--shadow);
  }

  .product-media {
    position: relative;
    display: grid;
    place-items: center;
    aspect-ratio: 4 / 3;
    background:
      linear-gradient(rgba(2, 6, 23, 0.05) 1px, transparent 1px),
      linear-gradient(90deg, rgba(2, 6, 23, 0.04) 1px, transparent 1px),
      #f8fafc;
    background-size: 32px 32px;
  }

  .product-media img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: contain;
    padding: 22px;
    z-index: 1;
  }

  .product-badge {
    position: absolute;
    top: 12px;
    left: 12px;
    z-index: 2;
    min-height: 30px;
    display: inline-flex;
    align-items: center;
    padding: 0 10px;
    border-radius: 999px;
    color: #fff;
    font-size: 0.82rem;
    font-weight: 800;
  }

  .badge-ok {
    background: var(--ok);
  }

  .badge-wait {
    background: var(--warn);
  }

  .media-fallback {
    display: grid;
    place-items: center;
    width: 108px;
    height: 108px;
    border-radius: var(--radius);
    background: #fff;
    border: 1px solid var(--line);
    color: var(--deep);
    font-family: "Space Grotesk", sans-serif;
    font-weight: 900;
  }

  .product-body {
    padding: 16px;
  }

  .product-category {
    color: var(--accent);
    font-weight: 800;
  }

  .product-meta {
    justify-content: space-between;
    gap: 12px;
    margin-top: 18px;
  }

  .product-meta strong {
    font-size: 1.05rem;
    font-variant-numeric: tabular-nums;
  }

  .card-link {
    min-height: 36px;
    display: inline-flex;
    align-items: center;
    padding: 0 10px;
    border-radius: var(--radius);
    background: #eef7ff;
    color: #0369a1;
    font-weight: 800;
  }

  .stock {
    padding: 5px 9px;
    border-radius: 999px;
    background: #eef2f7;
    font-weight: 800;
  }

  .stock-ok {
    color: var(--ok);
  }

  .stock-wait {
    color: var(--warn);
  }

  .breadcrumbs {
    gap: 8px;
    flex-wrap: wrap;
    padding-top: 24px;
  }

  .breadcrumbs a {
    color: #0369a1;
    font-weight: 700;
  }

  .page-title,
  .product-title {
    padding-block: 18px 34px;
    background:
      linear-gradient(120deg, rgba(14, 165, 233, 0.11), transparent 38%),
      #fff;
    border-bottom: 1px solid var(--line);
  }

  .page-title h1,
  .product-title h1 {
    font-size: clamp(2rem, 5vw, 4.6rem);
  }

  .page-title p,
  .product-title p {
    color: var(--muted);
  }

  .chips,
  .category-rail,
  .feature-strip,
  .product-kpis {
    gap: 8px;
    flex-wrap: wrap;
  }

  .chips {
    margin-top: 18px;
  }

  .chip,
  .category-pill {
    padding: 0 12px;
    background: #eef2f7;
    color: #344052;
    font-weight: 800;
  }

  .category-pill {
    background: #fff;
    border: 1px solid var(--line);
  }

  .category-pill:hover {
    border-color: var(--accent);
    color: #0369a1;
  }

  .feature-strip {
    padding: 16px clamp(16px, 4vw, 64px);
    background: #fff;
    border-bottom: 1px solid var(--line);
  }

  .feature-strip span {
    min-height: 40px;
    display: inline-flex;
    align-items: center;
    padding: 0 12px;
    border-radius: var(--radius);
    background: #f8fafc;
    color: #334155;
    font-weight: 800;
  }

  .content-band {
    display: grid;
    gap: 24px;
  }

  .text-content {
    width: 100%;
  }

  .text-content > :not(.eyebrow) {
    max-width: 900px;
  }

  .faq-list {
    display: grid;
    gap: 10px;
    max-width: 920px;
  }

  .faq-item {
    padding: 16px;
  }

  .faq-item h2 {
    margin: 0 0 8px;
    font-size: 1rem;
  }

  .product-detail {
    display: grid;
    grid-template-columns: minmax(300px, 0.85fr) minmax(0, 1.15fr);
    gap: 28px;
    padding-block: 34px 50px;
  }

  .product-gallery {
    min-height: 460px;
    border-radius: var(--radius);
    border: 1px solid var(--line);
    background:
      linear-gradient(rgba(2, 6, 23, 0.05) 1px, transparent 1px),
      linear-gradient(90deg, rgba(2, 6, 23, 0.04) 1px, transparent 1px),
      #f8fafc;
    background-size: 36px 36px;
    display: grid;
    place-items: center;
    position: sticky;
    top: 98px;
    box-shadow: var(--shadow);
  }

  .product-gallery > * {
    grid-area: 1 / 1;
  }

  .product-gallery img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    padding: 30px;
    z-index: 1;
  }

  .product-summary {
    display: grid;
    gap: 18px;
  }

  .price {
    font-size: clamp(1.8rem, 4vw, 2.7rem);
    font-weight: 900;
    font-variant-numeric: tabular-nums;
  }

  .spec-list {
    overflow: hidden;
  }

  .spec-row {
    display: grid;
    grid-template-columns: minmax(120px, 0.42fr) 1fr;
    gap: 12px;
    padding: 13px 14px;
    border-bottom: 1px solid var(--line);
  }

  .spec-row:last-child {
    border-bottom: 0;
  }

  .contact-panel,
  .info-card {
    padding: 18px;
  }

  .site-footer {
    display: grid;
    grid-template-columns: 1.1fr 1fr 0.8fr;
    gap: 28px;
    padding-block: 38px;
    background: var(--deep);
    color: #fff;
  }

  .site-footer p,
  .site-footer a,
  .footer-legal {
    color: #c7d2e3;
  }

  .footer-legal {
    display: block;
    margin-top: 14px;
    font-size: 0.88rem;
    line-height: 1.45;
  }

  .footer-brand {
    display: inline-flex;
    align-items: center;
    margin-bottom: 8px;
    color: #fff;
  }

  .site-footer .brand-logo-mark {
    width: 112px;
    height: 42px;
  }

  .site-footer .brand-logo-name {
    font-size: 1.18rem;
  }

  .site-footer .brand-logo-tag {
    color: #94a3b8;
    font-size: 0.68rem;
  }

  .footer-links {
    align-items: flex-start;
    flex-direction: column;
    gap: 8px;
  }

  @media (prefers-reduced-motion: reduce) {
    *,
    *::before,
    *::after {
      scroll-behavior: auto !important;
      transition-duration: 0.01ms !important;
      animation-duration: 0.01ms !important;
      animation-iteration-count: 1 !important;
    }
  }

  @media (max-width: 1020px) {
    .site-header {
      grid-template-columns: 1fr auto;
      padding-block: 12px;
    }

    .main-nav {
      display: none;
    }

    .header-action {
      display: none;
    }

    .mobile-menu-toggle {
      display: inline-grid;
      place-items: center;
    }

    .mobile-menu-overlay {
      position: fixed;
      inset: 76px 0 0;
      z-index: 38;
      display: block;
      background: rgba(2, 6, 23, 0.58);
      opacity: 0;
      pointer-events: none;
      transition: opacity 180ms ease;
    }

    .mobile-menu {
      position: fixed;
      inset: 76px 0 auto;
      z-index: 40;
      display: grid;
      grid-template-rows: auto auto auto auto 1fr auto;
      gap: 16px;
      width: 100%;
      max-height: calc(100dvh - 76px);
      padding: 16px;
      overflow-y: auto;
      background: var(--deep);
      color: #fff;
      border-top: 1px solid rgba(255, 255, 255, 0.12);
      box-shadow: 0 24px 70px rgba(0, 0, 0, 0.34);
      opacity: 0;
      pointer-events: none;
      scrollbar-width: none;
      transform: translateY(-12px);
      transition:
        opacity 180ms ease,
        transform 220ms cubic-bezier(0.16, 1, 0.3, 1);
    }

    .mobile-menu::-webkit-scrollbar {
      display: none;
    }

    .mobile-menu-open {
      overflow: hidden;
    }

    .mobile-menu-open .mobile-menu-overlay {
      opacity: 1;
      pointer-events: auto;
    }

    .mobile-menu-open .mobile-menu {
      opacity: 1;
      pointer-events: auto;
      transform: translateY(0);
    }

    .mobile-menu-open .mobile-menu-toggle {
      background: rgba(14, 165, 233, 0.16);
      border-color: rgba(125, 211, 252, 0.55);
      box-shadow:
        0 0 0 1px rgba(14, 165, 233, 0.12),
        0 14px 30px rgba(14, 165, 233, 0.18),
        inset 0 0 18px rgba(14, 165, 233, 0.12);
    }

    .mobile-menu-open .mobile-menu-toggle span:nth-child(1) {
      transform: translateY(0) rotate(45deg);
    }

    .mobile-menu-open .mobile-menu-toggle span:nth-child(2) {
      opacity: 0;
      transform: scaleX(0.24);
    }

    .mobile-menu-open .mobile-menu-toggle span:nth-child(3) {
      transform: translateY(0) rotate(-45deg);
    }

    .mobile-menu-head {
      justify-content: space-between;
      gap: 16px;
    }

    .mobile-menu-head strong {
      display: block;
      font-family: "Space Grotesk", sans-serif;
      font-size: 1.2rem;
    }

    .mobile-menu-head span,
    .mobile-search-label,
    .mobile-result small,
    .mobile-category-list small,
    .mobile-empty {
      color: #9fb0c8;
    }

    .mobile-search-label {
      display: block;
      margin-bottom: -8px;
      font-size: 0.86rem;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 0.08em;
    }

    .mobile-search-field {
      gap: 10px;
      min-height: 52px;
      padding: 0 14px;
      border: 1px solid rgba(255, 255, 255, 0.14);
      border-radius: var(--radius);
      background: rgba(255, 255, 255, 0.08);
      color: #dbeafe;
    }

    .mobile-search-field input {
      width: 100%;
      min-width: 0;
      border: 0;
      outline: 0;
      background: transparent;
      color: #fff;
      font: inherit;
    }

    .mobile-search-field input::placeholder {
      color: #8ea1bb;
    }

    .mobile-search-results {
      display: grid;
      gap: 8px;
    }

    .mobile-result,
    .mobile-category-list a {
      display: grid;
      gap: 3px;
      padding: 12px;
      border: 1px solid rgba(255, 255, 255, 0.1);
      border-radius: var(--radius);
      background: rgba(255, 255, 255, 0.06);
    }

    .mobile-result span {
      color: #7dd3fc;
      font-size: 0.78rem;
      font-weight: 900;
      text-transform: uppercase;
      letter-spacing: 0.08em;
    }

    .mobile-result strong,
    .mobile-category-list span {
      color: #fff;
      font-weight: 900;
    }

    .mobile-result small,
    .mobile-category-list small {
      line-height: 1.35;
    }

    .mobile-empty {
      margin: 0;
      padding: 12px;
      border-radius: var(--radius);
      background: rgba(255, 255, 255, 0.06);
    }

    .mobile-menu-section {
      display: grid;
      gap: 10px;
    }

    .mobile-menu-section h2 {
      margin: 0;
      font-size: 1rem;
    }

    .mobile-category-list {
      display: grid;
      gap: 8px;
    }

    .store-hero,
    .product-detail,
    .site-footer {
      grid-template-columns: 1fr;
    }

    .store-hero {
      min-height: auto;
    }

    .hero-visual {
      min-height: auto;
    }

    .product-gallery {
      min-height: 330px;
      position: relative;
      top: auto;
    }
  }

  @media (max-width: 680px) {
    .header-action {
      display: none;
    }

    .section-heading {
      align-items: flex-start;
      flex-direction: column;
    }

    .brand-logo {
      gap: 10px;
    }

    .brand-logo-mark {
      width: 116px;
      height: 42px;
    }

    .brand-logo-name {
      font-size: 1.12rem;
    }

    .brand-logo-tag {
      font-size: 0.66rem;
    }

    .store-hero h1,
    .page-title h1,
    .product-title h1 {
      font-size: 2.25rem;
    }

    .hero-device {
      grid-template-columns: 1fr;
    }

    .hero-product {
      min-height: 270px;
    }

    .product-meta,
    .actions {
      align-items: stretch;
      flex-direction: column;
    }

    .button {
      width: 100%;
    }

    .stat {
      flex: 1 1 145px;
    }

    .spec-row {
      grid-template-columns: 1fr;
    }
  }

  /* Storefront redesign inspired by modern electronics catalogs. */
  :root {
    --ink: #111827;
    --muted: #687385;
    --line: #e5e7eb;
    --panel: #ffffff;
    --soft: #f6f7f9;
    --deep: #06070a;
    --deep-2: #151820;
    --accent: #ef233c;
    --accent-2: #ffb703;
    --accent-3: #0ea5e9;
    --ok: #11845b;
    --warn: #a16207;
    --shadow: 0 18px 44px rgba(17, 24, 39, 0.12);
    --radius: 12px;
  }

  body {
    background: #fff;
    color: var(--ink);
  }

  body::before {
    display: none;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    display: block;
    min-height: auto;
    padding: 0;
    background: #fff;
    color: var(--ink);
    border-bottom: 1px solid var(--line);
    box-shadow: 0 12px 30px rgba(17, 24, 39, 0.06);
    backdrop-filter: none;
  }

  .topbar,
  .header-main,
  .commerce-nav,
  .category-showcase,
  .shop-hero-grid,
  .promo-grid,
  .section,
  .service-band,
  .content-band {
    padding-inline: clamp(16px, 4vw, 54px);
  }

  .topbar {
    min-height: 42px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 18px;
    background: #050505;
    color: #f9fafb;
    font-size: 0.88rem;
    font-weight: 700;
  }

  .topbar-group {
    display: flex;
    align-items: center;
    gap: 18px;
    min-width: 0;
  }

  .topbar a,
  .topbar span {
    color: rgba(255, 255, 255, 0.86);
    white-space: nowrap;
  }

  .topbar a:hover {
    color: #fff;
  }

  .topbar-meta span {
    position: relative;
  }

  .topbar-meta span + span::before {
    content: "";
    position: absolute;
    left: -10px;
    top: 50%;
    width: 1px;
    height: 14px;
    background: rgba(255, 255, 255, 0.26);
    transform: translateY(-50%);
  }

  .header-main {
    display: grid;
    grid-template-columns: auto minmax(360px, 1fr) auto;
    align-items: center;
    gap: clamp(18px, 3vw, 34px);
    min-height: 92px;
    background: #fff;
  }

  .site-header .brand-logo,
  .site-header .brand-logo-name {
    color: var(--ink);
  }

  .site-header .brand-logo-name span {
    color: #0369a1;
  }

  .site-header .brand-logo-tag {
    color: #7b8494;
  }

  .desktop-search {
    position: relative;
    min-width: 0;
  }

  .search-shell {
    display: grid;
    grid-template-columns: minmax(130px, 178px) auto 22px minmax(0, 1fr) 112px;
    align-items: center;
    min-height: 54px;
    border: 1px solid #d7dce4;
    border-radius: 999px;
    background: #fff;
    box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.75);
    overflow: hidden;
  }

  .search-shell select,
  .search-shell input {
    min-width: 0;
    border: 0;
    outline: 0;
    background: transparent;
    color: var(--ink);
    font: inherit;
  }

  .search-shell select {
    height: 100%;
    padding: 0 12px 0 20px;
    font-weight: 800;
    cursor: pointer;
  }

  .search-shell input {
    width: 100%;
    height: 100%;
    padding: 0 12px;
  }

  .search-shell input::placeholder {
    color: #8b95a5;
  }

  .search-shell svg {
    width: 21px;
    height: 21px;
    fill: none;
    stroke: currentColor;
    stroke-width: 2;
    stroke-linecap: round;
    stroke-linejoin: round;
    color: #687385;
  }

  .search-divider {
    width: 1px;
    height: 26px;
    background: #d7dce4;
  }

  .search-submit {
    width: calc(100% - 6px);
    height: 42px;
    border: 0;
    border-radius: 999px;
    background: var(--accent);
    color: #fff;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 7px;
    font: inherit;
    font-weight: 900;
    transition:
      transform 180ms ease,
      background-color 180ms ease,
      box-shadow 180ms ease;
  }

  .search-submit:hover {
    transform: translateX(1px);
    background: #d90429;
    box-shadow: 0 10px 20px rgba(239, 35, 60, 0.26);
  }

  .search-submit svg {
    width: 18px;
    height: 18px;
    color: #fff;
  }

  .catalog-search-results {
    position: absolute;
    top: calc(100% + 10px);
    left: 0;
    right: 0;
    z-index: 80;
    display: grid;
    gap: 8px;
    max-height: 360px;
    padding: 10px;
    overflow-y: auto;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: #fff;
    box-shadow: var(--shadow);
  }

  .catalog-search-results[hidden] {
    display: none;
  }

  .catalog-result {
    display: grid;
    gap: 2px;
    padding: 11px 12px;
    border-radius: 10px;
    background: #f8fafc;
    transition:
      background-color 160ms ease,
      transform 160ms ease;
  }

  .catalog-result:hover {
    background: #fff1f2;
    transform: translateX(2px);
  }

  .catalog-result span {
    color: var(--accent);
    font-size: 0.76rem;
    font-weight: 900;
    text-transform: uppercase;
  }

  .catalog-result strong {
    line-height: 1.2;
  }

  .catalog-result small {
    color: var(--muted);
  }

  .header-tools {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .tool-link {
    display: grid;
    gap: 1px;
    min-height: 48px;
    padding: 7px 10px;
    border-radius: 10px;
    transition:
      background-color 180ms ease,
      transform 180ms ease;
  }

  .tool-link:hover {
    background: #f3f4f6;
    transform: translateY(-1px);
  }

  .tool-link span {
    color: var(--muted);
    font-size: 0.76rem;
    font-weight: 800;
  }

  .tool-link strong {
    white-space: nowrap;
    font-size: 0.92rem;
  }

  .cart-link {
    min-width: 58px;
    min-height: 50px;
    display: grid;
    place-items: center;
    gap: 1px;
    padding: 6px 10px;
    border-radius: 10px;
    background: #111827;
    color: #fff;
    font-size: 0.75rem;
    font-weight: 900;
    transition:
      transform 180ms ease,
      background-color 180ms ease;
  }

  .cart-link:hover {
    transform: translateY(-1px);
    background: #000;
  }

  .cart-link svg,
  .browse-button svg,
  .quick-view svg {
    width: 22px;
    height: 22px;
    fill: none;
    stroke: currentColor;
    stroke-width: 2;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .commerce-nav {
    display: grid;
    grid-template-columns: minmax(240px, 300px) minmax(0, 1fr) auto;
    align-items: center;
    gap: 18px;
    min-height: 58px;
    border-top: 1px solid var(--line);
    background: #fff;
  }

  .browse-button,
  .special-offer {
    min-height: 44px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    border-radius: 0;
    font-weight: 900;
  }

  .browse-button {
    justify-content: flex-start;
    padding: 0 18px;
    background: #050505;
    color: #fff;
  }

  .special-offer {
    color: var(--accent);
    white-space: nowrap;
  }

  .commerce-nav .main-nav {
    gap: 0;
  }

  .commerce-nav .main-nav a {
    color: #374151;
    font-weight: 800;
    padding-inline: 11px;
  }

  .commerce-nav .main-nav a:hover {
    background: #f3f4f6;
    color: #111827;
  }

  .mobile-menu-toggle {
    border-color: #d1d5db;
    background: #fff;
    color: #111827;
  }

  .category-showcase,
  .shop-hero-grid,
  .promo-grid,
  .section,
  .service-band {
    max-width: 1320px;
    margin-inline: auto;
  }

  .category-showcase {
    padding-block: 22px 16px;
  }

  .category-showcase-head {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 18px;
    margin-bottom: 16px;
  }

  .category-showcase .breadcrumbs {
    padding-top: 0;
    margin-bottom: 8px;
  }

  .category-showcase h2 {
    margin: 0;
    font-size: clamp(1.4rem, 2.4vw, 2rem);
  }

  .showcase-link {
    color: var(--accent);
    font-weight: 900;
    white-space: nowrap;
  }

  .category-showcase-actions {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .carousel-button {
    width: 42px;
    height: 42px;
    display: inline-grid;
    place-items: center;
    border: 1px solid var(--line);
    border-radius: 999px;
    background: #fff;
    color: #111827;
    cursor: pointer;
    transition:
      transform 180ms ease,
      border-color 180ms ease,
      background-color 180ms ease,
      color 180ms ease,
      box-shadow 180ms ease;
  }

  .carousel-button:hover {
    transform: translateY(-1px);
    border-color: var(--accent);
    background: var(--accent);
    color: #fff;
    box-shadow: 0 12px 24px rgba(239, 35, 60, 0.2);
  }

  .carousel-button svg {
    width: 22px;
    height: 22px;
    fill: none;
    stroke: currentColor;
    stroke-width: 2.3;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .category-showcase-track {
    display: grid;
    grid-auto-flow: column;
    grid-auto-columns: minmax(168px, 190px);
    grid-template-columns: none;
    gap: 14px;
    overflow-x: auto;
    scroll-snap-type: x proximity;
    padding-bottom: 6px;
    scrollbar-width: none;
    cursor: grab;
    overscroll-behavior-inline: contain;
    user-select: none;
  }

  .category-showcase-track::-webkit-scrollbar {
    display: none;
  }

  .category-showcase-track.is-dragging {
    cursor: grabbing;
    scroll-snap-type: none;
  }

  .category-showcase-card {
    min-height: 178px;
    display: grid;
    align-content: space-between;
    gap: 10px;
    padding: 14px;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: #f7f8fa;
    overflow: hidden;
    opacity: 0;
    transform: translateY(12px);
    animation: storeFadeUp 520ms cubic-bezier(0.16, 1, 0.3, 1) forwards;
    animation-delay: var(--delay);
    scroll-snap-align: start;
    transition:
      transform 220ms ease,
      border-color 220ms ease,
      box-shadow 220ms ease,
      background-color 220ms ease;
  }

  .category-showcase-card:hover {
    background: #fff;
    border-color: #cfd6df;
    box-shadow: var(--shadow);
    transform: translateY(-4px);
  }

  .category-thumb {
    display: grid;
    place-items: center;
    min-height: 90px;
  }

  .category-thumb img {
    width: 100%;
    height: 96px;
    object-fit: contain;
    transform: scale(1);
    transition: transform 240ms ease;
  }

  .category-showcase-card:hover .category-thumb img {
    transform: scale(1.06) rotate(-1deg);
  }

  .category-showcase-card strong {
    line-height: 1.15;
  }

  .category-showcase-card small {
    color: var(--muted);
    font-weight: 800;
  }

  .shop-hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.48fr) minmax(320px, 0.78fr);
    gap: 18px;
    padding-block: 16px 20px;
  }

  .hero-side-banners {
    display: grid;
    gap: 18px;
  }

  .hero-banner,
  .promo-tile {
    position: relative;
    display: grid;
    overflow: hidden;
    border-radius: var(--radius);
    color: #fff;
    background: #111827;
    isolation: isolate;
    transition:
      transform 220ms ease,
      box-shadow 220ms ease;
  }

  .hero-banner:hover,
  .promo-tile:hover {
    transform: translateY(-3px);
    box-shadow: 0 22px 54px rgba(17, 24, 39, 0.2);
  }

  .hero-banner::before,
  .promo-tile::before {
    content: "";
    position: absolute;
    inset: 0;
    z-index: -1;
    background:
      linear-gradient(90deg, rgba(0, 0, 0, 0.78), rgba(0, 0, 0, 0.2)),
      repeating-linear-gradient(135deg, rgba(255, 255, 255, 0.08) 0 1px, transparent 1px 12px);
  }

  .hero-banner-large {
    min-height: 500px;
    grid-template-columns: minmax(0, 1fr) minmax(320px, 0.96fr);
    align-items: center;
    padding: clamp(28px, 4vw, 54px);
    background:
      linear-gradient(120deg, #0b0d13, #20242d 58%, #f1f5f9 58%);
  }

  .hero-banner-large::after {
    content: "";
    position: absolute;
    right: 42%;
    top: 0;
    bottom: 0;
    width: 120px;
    background: var(--accent);
    transform: skewX(-12deg);
    opacity: 0.96;
    z-index: -1;
  }

  .banner-copy {
    position: relative;
    z-index: 2;
  }

  .banner-kicker {
    display: inline-flex;
    align-items: center;
    min-height: 28px;
    padding: 0 10px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.14);
    color: #fff;
    font-size: 0.78rem;
    font-weight: 900;
    text-transform: uppercase;
  }

  .hero-banner h1,
  .hero-banner h2,
  .promo-tile h2 {
    margin: 14px 0 10px;
    letter-spacing: 0;
  }

  .hero-banner h1 {
    max-width: 560px;
    font-size: clamp(2.15rem, 3.2vw, 3rem);
    line-height: 1.06;
    overflow-wrap: normal;
  }

  .hero-banner h2,
  .promo-tile h2 {
    max-width: 360px;
    font-size: clamp(1.35rem, 2.4vw, 2.15rem);
    line-height: 1.06;
  }

  .hero-banner p,
  .promo-tile p {
    max-width: 540px;
    color: rgba(255, 255, 255, 0.78);
    margin: 0;
  }

  .banner-cta,
  .banner-price {
    display: inline-flex;
    align-items: center;
    min-height: 42px;
    margin-top: 22px;
    padding: 0 16px;
    border-radius: 999px;
    background: #fff;
    color: #111827;
    font-weight: 900;
  }

  .banner-product {
    position: relative;
    display: grid;
    place-items: center;
    min-height: 420px;
  }

  .banner-product img {
    width: min(100%, 600px);
    max-height: 440px;
    object-fit: contain;
    filter: drop-shadow(0 24px 34px rgba(0, 0, 0, 0.24));
    animation: productFloat 4.8s ease-in-out infinite;
  }

  .sale-badge {
    position: absolute;
    top: 12%;
    right: 10%;
    z-index: 3;
    display: grid;
    place-items: center;
    width: 92px;
    height: 92px;
    border-radius: 999px;
    background: var(--accent);
    color: #fff;
    text-align: center;
    font-size: 0.82rem;
    font-weight: 900;
    line-height: 1.1;
    box-shadow: 0 16px 34px rgba(239, 35, 60, 0.26);
    animation: badgePulse 2.8s ease-in-out infinite;
  }

  .hero-banner-compact {
    min-height: 241px;
    grid-template-columns: minmax(0, 1fr) 42%;
    align-items: center;
    padding: 26px;
  }

  .hero-banner-compact img {
    width: 100%;
    height: 205px;
    object-fit: contain;
    filter: drop-shadow(0 16px 28px rgba(0, 0, 0, 0.22));
    transition: transform 240ms ease;
  }

  .hero-banner-compact:hover img {
    transform: scale(1.06) translateY(-3px);
  }

  .banner-dark {
    background: linear-gradient(135deg, #101319, #2c313b);
  }

  .banner-red {
    background: linear-gradient(135deg, #8f1224, #ef233c);
  }

  .feature-strip {
    max-width: 1320px;
    margin: 0 auto;
    padding-block: 12px;
