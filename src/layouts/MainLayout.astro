---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import SeoHead from "../components/SeoHead.astro";
import { site } from "../lib/catalog";

const {
  title = site.title,
  description = site.description,
  canonical = "/",
  ogType = "website",
  schema = []
} = Astro.props;
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@400;500;600;700&family=JetBrains+Mono:wght@600;700&display=swap"
      rel="stylesheet"
    />
    <SeoHead
      title={title}
      description={description}
      canonical={canonical}
      ogType={ogType}
      schema={schema}
    />
  </head>
  <body>
    <a class="skip-link" href="#content">К содержимому</a>
    <Header />
    <main id="content">
      <slot />
    </main>
    <Footer />
    <nav class="mobile-bottom-bar" aria-label="Быстрые действия">
      <a href="/#categories">Каталог</a>
      <a href="#site-search">Поиск</a>
      <a href={site.telegram}>Telegram</a>
      <a href={`tel:${site.phone.replaceAll(" ", "")}`}>Позвонить</a>
    </nav>
  </body>
</html>

<style is:global>
  :root {
    color-scheme: light;
    --ink: #111827;
    --muted: #5b6677;
    --soft: #f5f7fb;
    --panel: #ffffff;
    --line: #dce4ee;
    --primary: #0f77c8;
    --primary-dark: #075a9d;
    --teal: #0f9f8f;
    --sale: #f97316;
    --danger: #dc2626;
    --success: #12805c;
    --shadow: 0 16px 40px rgba(15, 23, 42, 0.1);
    --radius: 8px;
    --container: 1200px;
    font-family: "IBM Plex Sans", ui-sans-serif, system-ui, -apple-system, "Segoe UI", sans-serif;
  }

  * {
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    margin: 0;
    background: var(--soft);
    color: var(--ink);
    font-size: 16px;
    line-height: 1.55;
    padding-bottom: 72px;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  a,
  button,
  input,
  select {
    font: inherit;
  }

  a,
  button {
    touch-action: manipulation;
  }

  a:focus-visible,
  button:focus-visible,
  input:focus-visible,
  select:focus-visible {
    outline: 3px solid rgba(15, 119, 200, 0.35);
    outline-offset: 3px;
  }

  img {
    display: block;
    max-width: 100%;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  h1,
  h2,
  h3,
  .price,
  .brand-logo-name {
    font-family: "JetBrains Mono", "IBM Plex Sans", sans-serif;
    letter-spacing: 0;
  }

  main {
    min-height: 60vh;
  }

  .skip-link {
    position: fixed;
    top: 10px;
    left: 10px;
    z-index: 200;
    transform: translateY(-140%);
    padding: 10px 12px;
    border-radius: var(--radius);
    background: #fff;
    color: var(--ink);
    font-weight: 700;
    box-shadow: var(--shadow);
  }

  .skip-link:focus {
    transform: translateY(0);
  }

  .container,
  .section,
  .page-title,
  .product-title,
  .product-detail,
  .content-band,
  .site-footer,
  .home-hero,
  .promo-grid,
  .benefits-row,
  .category-showcase {
    width: min(100% - 28px, var(--container));
    margin-inline: auto;
  }

  .topbar {
    background: #0b1220;
    color: #e5eef9;
    font-size: 0.88rem;
  }

  .topbar-inner {
    width: min(100% - 28px, var(--container));
    min-height: 36px;
    margin-inline: auto;
    display: flex;
    gap: 12px;
    align-items: center;
    justify-content: space-between;
    overflow-x: auto;
    scrollbar-width: none;
    white-space: nowrap;
  }

  .topbar-inner::-webkit-scrollbar {
    display: none;
  }

  .site-header {
    position: sticky;
    top: 0;
    z-index: 60;
    background: rgba(255, 255, 255, 0.96);
    border-bottom: 1px solid var(--line);
    backdrop-filter: blur(16px);
  }

  .header-main {
    width: min(100% - 28px, var(--container));
    margin-inline: auto;
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto auto;
    gap: 8px;
    align-items: center;
    min-height: 62px;
  }

  .brand,
  .brand-logo,
  .brand-logo-text,
  .header-actions,
  .main-nav,
  .chips,
  .category-rail,
  .product-kpis,
  .actions,
  .breadcrumbs,
  .mobile-bottom-bar,
  .product-card-actions,
  .benefit,
  .filter-actions,
  .gallery-thumbs {
    display: flex;
    align-items: center;
  }

  .brand-logo {
    gap: 8px;
    min-width: 0;
  }

  .brand-logo-mark {
    width: 104px;
    height: 38px;
  }

  .brand-logo-text {
    flex-direction: column;
    align-items: flex-start;
    line-height: 1;
  }

  .brand-logo-name {
    font-weight: 800;
    font-size: 1rem;
  }

  .brand-logo-name span {
    color: var(--primary);
  }

  .brand-logo-tag {
    margin-top: 3px;
    color: var(--muted);
    font-size: 0.68rem;
    font-weight: 700;
    text-transform: uppercase;
  }

  .header-actions {
    gap: 8px;
  }

  .header-action,
  .button,
  .search-submit,
  .mobile-menu-toggle,
  .category-pill,
  .chip,
  .filter-chip {
    min-height: 44px;
    border-radius: var(--radius);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    border: 1px solid transparent;
    font-weight: 700;
    cursor: pointer;
    transition: background-color 180ms ease, border-color 180ms ease, color 180ms ease, transform 180ms ease, box-shadow 180ms ease;
  }

  .header-action {
    padding: 0 12px;
    background: var(--primary);
    color: #fff;
  }

  .header-action.secondary {
    display: none;
    background: #eef6ff;
    color: var(--primary-dark);
    border-color: #cce4fb;
  }

  .mobile-menu-toggle {
    width: 44px;
    background: #fff;
    border-color: var(--line);
    color: var(--ink);
  }

  .mobile-menu-toggle span {
    width: 20px;
    height: 2px;
    display: block;
    border-radius: 99px;
    background: currentColor;
    box-shadow: 0 6px 0 currentColor, 0 -6px 0 currentColor;
  }

  .search-row {
    width: min(100% - 28px, var(--container));
    margin: 0 auto 10px;
    position: relative;
  }

  .desktop-search {
    display: none;
  }

  .search-shell,
  .mobile-search-field {
    min-height: 48px;
    display: grid;
    grid-template-columns: auto minmax(0, 1fr) auto;
    gap: 8px;
    align-items: center;
    padding: 4px;
    border: 1px solid var(--line);
    border-radius: 12px;
    background: #fff;
    box-shadow: 0 10px 22px rgba(15, 23, 42, 0.06);
  }

  .search-shell svg,
  .mobile-search-field svg {
    width: 22px;
    height: 22px;
    margin-left: 10px;
    fill: none;
    stroke: var(--muted);
    stroke-width: 2;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .search-shell input,
  .mobile-search-field input {
    width: 100%;
    min-width: 0;
    min-height: 40px;
    border: 0;
    outline: 0;
    color: var(--ink);
    background: transparent;
  }

  .search-submit {
    min-height: 40px;
    padding: 0 12px;
    background: var(--primary);
    color: #fff;
  }

  .catalog-search-results {
    position: absolute;
    left: 0;
    right: 0;
    top: calc(100% + 6px);
    z-index: 90;
    display: grid;
    gap: 8px;
    max-height: 340px;
    overflow-y: auto;
    padding: 10px;
    border: 1px solid var(--line);
    border-radius: 12px;
    background: #fff;
    box-shadow: var(--shadow);
  }

  .catalog-search-results[hidden] {
    display: none;
  }

  .catalog-result {
    display: grid;
    gap: 2px;
    padding: 10px;
    border-radius: var(--radius);
    background: var(--soft);
  }

  .catalog-result span {
    color: var(--primary);
    font-size: 0.74rem;
    font-weight: 800;
    text-transform: uppercase;
  }

  .catalog-result small,
  .mobile-empty {
    color: var(--muted);
  }

  .commerce-nav {
    display: none;
  }

  .mobile-menu-overlay,
  .mobile-menu {
    display: none;
  }

  .mobile-menu-open {
    overflow: hidden;
  }

  .mobile-menu-open .mobile-menu-overlay {
    position: fixed;
    inset: 0;
    z-index: 70;
    display: block;
    background: rgba(15, 23, 42, 0.45);
  }

  .mobile-menu-open .mobile-menu {
    position: fixed;
    inset: auto 0 0;
    z-index: 80;
    display: grid;
    gap: 16px;
    max-height: 82dvh;
    padding: 18px 14px 22px;
    overflow-y: auto;
    border-radius: 18px 18px 0 0;
    background: #fff;
    box-shadow: 0 -20px 40px rgba(15, 23, 42, 0.22);
  }

  .mobile-category-list {
    display: grid;
    gap: 8px;
  }

  .mobile-category-list a {
    display: grid;
    gap: 2px;
    min-height: 56px;
    padding: 10px 12px;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: var(--soft);
  }

  .mobile-category-list small {
    color: var(--muted);
  }

  .section,
  .category-showcase {
    padding-block: 28px;
  }

  .section-heading {
    display: flex;
    gap: 14px;
    align-items: flex-end;
    justify-content: space-between;
    margin-bottom: 16px;
  }

  .section-heading h2,
  .page-title h1,
  .product-title h1,
  .home-hero h1 {
    margin: 0;
    line-height: 1.08;
  }

  .eyebrow {
    margin: 0 0 8px;
    color: var(--primary);
    font-size: 0.8rem;
    font-weight: 800;
    text-transform: uppercase;
  }

  .home-hero {
    display: grid;
    gap: 18px;
    padding-block: 22px;
  }

  .hero-panel {
    display: grid;
    gap: 18px;
    overflow: hidden;
    padding: 22px;
    border-radius: 14px;
    background: linear-gradient(135deg, #0b1220, #123d64 58%, #e8f6ff);
    color: #fff;
  }

  .home-hero h1 {
    max-width: 780px;
    font-size: clamp(1.9rem, 9vw, 4.6rem);
  }

  .hero-panel p {
    max-width: 680px;
    margin: 0;
    color: #d8e7f5;
  }

  .hero-media {
    display: grid;
    place-items: center;
    min-height: 230px;
    border-radius: 12px;
    background: rgba(255, 255, 255, 0.9);
  }

  .hero-media img {
    width: min(100%, 430px);
    height: 250px;
    object-fit: contain;
    padding: 18px;
  }

  .actions {
    flex-wrap: wrap;
    gap: 10px;
  }

  .button {
    padding: 0 16px;
  }

  .button-primary {
    background: var(--primary);
    color: #fff;
  }

  .button-secondary {
    background: #fff;
    border-color: var(--line);
    color: var(--ink);
  }

  .button-telegram {
    background: var(--teal);
    color: #fff;
  }

  .category-rail,
  .chips {
    gap: 8px;
    overflow-x: auto;
    padding-bottom: 4px;
    scrollbar-width: none;
  }

  .category-rail::-webkit-scrollbar,
  .chips::-webkit-scrollbar {
    display: none;
  }

  .category-pill,
  .chip,
  .filter-chip {
    flex: 0 0 auto;
    min-height: 40px;
    padding: 0 12px;
    background: #fff;
    border-color: var(--line);
    color: #2f3a4a;
  }

  .promo-grid,
  .benefits-row {
    display: grid;
    gap: 12px;
    padding-block: 8px 24px;
  }

  .promo-card,
  .benefit,
  .category-card,
  .product-card,
  .info-card,
  .contact-panel,
  .faq-item,
  .filter-card,
  .spec-list,
  .delivery-card {
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: var(--panel);
    box-shadow: 0 10px 28px rgba(15, 23, 42, 0.06);
  }

  .promo-card {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 110px;
    gap: 12px;
    align-items: center;
    min-height: 144px;
    padding: 16px;
  }

  .promo-card img,
  .category-card img {
    width: 100%;
    height: 104px;
    object-fit: contain;
  }

  .promo-card h2,
  .category-card h3,
  .product-card h3 {
    margin: 0;
    line-height: 1.2;
  }

  .promo-card p,
  .product-card p,
  .page-title p,
  .product-title p,
  .info-card p,
  .faq-item p,
  .delivery-card p,
  .footer-legal {
    color: var(--muted);
  }

  .benefit {
    gap: 10px;
    min-height: 58px;
    padding: 12px;
    font-weight: 700;
  }

  .benefit svg,
  .mobile-bottom-bar svg {
    width: 22px;
    height: 22px;
    fill: none;
    stroke: currentColor;
    stroke-width: 2;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .category-grid,
  .grid {
    display: grid;
    gap: 14px;
  }

  .category-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .category-card {
    display: grid;
    gap: 10px;
    padding: 14px;
  }

  .grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .product-card {
    overflow: hidden;
  }

  .product-media {
    position: relative;
    aspect-ratio: 1 / 0.86;
    display: grid;
    place-items: center;
    background: #f8fafc;
  }

  .media-image-link {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
  }

  .product-media img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    padding: 14px;
  }

  .product-badges {
    position: absolute;
    top: 8px;
    left: 8px;
    right: 8px;
    z-index: 2;
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
  }

  .product-badge {
    min-height: 26px;
    display: inline-flex;
    align-items: center;
    padding: 0 8px;
    border-radius: 999px;
    background: var(--success);
    color: #fff;
    font-size: 0.72rem;
    font-weight: 800;
  }

  .badge-sale {
    background: var(--sale);
  }

  .badge-hit {
    background: #111827;
  }

  .badge-new {
    background: var(--primary);
  }

  .badge-wait {
    background: #8a5a08;
  }

  .product-body {
    display: grid;
    gap: 8px;
    padding: 12px;
  }

  .product-category {
    color: var(--primary);
    font-size: 0.78rem;
    font-weight: 800;
  }

  .product-card h3 {
    min-height: 2.4em;
    display: -webkit-box;
    overflow: hidden;
    font-size: 0.95rem;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
  }

  .product-spec {
    min-height: 2.8em;
    display: -webkit-box;
    overflow: hidden;
    font-size: 0.86rem;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
  }

  .price-row {
    display: grid;
    gap: 2px;
  }

  .price {
    font-weight: 800;
    font-size: 1rem;
    font-variant-numeric: tabular-nums;
  }

  .old-price {
    color: #8a94a6;
    font-size: 0.85rem;
    text-decoration: line-through;
  }

  .stock {
    color: var(--success);
    font-size: 0.85rem;
    font-weight: 800;
  }

  .stock-wait {
    color: #8a5a08;
  }

  .product-card-actions {
    gap: 8px;
    align-items: stretch;
  }

  .product-card-actions .button {
    flex: 1 1 auto;
    min-height: 42px;
    padding-inline: 10px;
    font-size: 0.9rem;
  }

  .product-card-actions .button-secondary {
    flex: 0 0 auto;
  }

  .page-title,
  .product-title {
    padding-block: 18px 24px;
  }

  .page-title h1,
  .product-title h1 {
    font-size: clamp(1.75rem, 8vw, 3.6rem);
  }

  .breadcrumbs {
    gap: 7px;
    flex-wrap: wrap;
    margin-bottom: 12px;
    color: var(--muted);
    font-size: 0.9rem;
  }

  .breadcrumbs a {
    color: var(--primary-dark);
    font-weight: 700;
  }

  .category-layout {
    display: grid;
    gap: 16px;
  }

  .filter-actions {
    gap: 8px;
    margin-bottom: 14px;
  }

  .filter-card {
    display: none;
    padding: 16px;
  }

  .filter-sheet-open .filter-card {
    position: fixed;
    inset: auto 0 0;
    z-index: 100;
    display: grid;
    gap: 12px;
    max-height: 78dvh;
    overflow-y: auto;
    padding: 18px 14px 24px;
    border-radius: 18px 18px 0 0;
    box-shadow: 0 -20px 44px rgba(15, 23, 42, 0.24);
  }

  .filter-sheet-open::after {
    content: "";
    position: fixed;
    inset: 0;
    z-index: 99;
    background: rgba(15, 23, 42, 0.45);
  }

  .filter-card h2 {
    margin: 0;
    font-size: 1.1rem;
  }

  .content-band {
    display: grid;
    gap: 14px;
    padding-block: 24px 34px;
  }

  .info-card,
  .contact-panel,
  .delivery-card {
    padding: 16px;
  }

  .faq-list {
    display: grid;
    gap: 10px;
  }

  .faq-item {
    padding: 0;
    overflow: hidden;
  }

  .faq-item summary {
    min-height: 54px;
    padding: 14px 16px;
    cursor: pointer;
    font-weight: 800;
  }

  .faq-item p {
    margin: 0;
    padding: 0 16px 16px;
  }

  .product-detail {
    display: grid;
    gap: 16px;
    padding-block: 10px 26px;
  }

  .product-gallery {
    display: grid;
    gap: 10px;
  }

  .gallery-main {
    display: grid;
    place-items: center;
    min-height: 320px;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: #fff;
  }

  .gallery-main img {
    width: 100%;
    height: 320px;
    object-fit: contain;
    padding: 18px;
  }

  .gallery-thumbs {
    gap: 8px;
    overflow-x: auto;
    scrollbar-width: none;
  }

  .gallery-thumb {
    flex: 0 0 72px;
    height: 72px;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: #fff;
    cursor: pointer;
  }

  .gallery-thumb img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    padding: 6px;
  }

  .product-summary {
    display: grid;
    gap: 14px;
  }

  .product-summary .price {
    font-size: clamp(1.55rem, 7vw, 2.4rem);
  }

  .product-kpis {
    gap: 8px;
    flex-wrap: wrap;
  }

  .spec-list {
    overflow: hidden;
  }

  .spec-row {
    display: grid;
    grid-template-columns: minmax(110px, 0.42fr) 1fr;
    gap: 10px;
    padding: 12px;
    border-bottom: 1px solid var(--line);
  }

  .spec-row:last-child {
    border-bottom: 0;
  }

  .spec-label {
    color: var(--muted);
  }

  .sticky-product-cta {
    position: sticky;
    bottom: 72px;
    z-index: 40;
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 8px;
    padding: 10px;
    border: 1px solid var(--line);
    border-radius: 14px;
    background: rgba(255, 255, 255, 0.96);
    box-shadow: var(--shadow);
    backdrop-filter: blur(16px);
  }

  .site-footer {
    display: grid;
    gap: 22px;
    padding-block: 34px 92px;
    color: #d6e0ec;
    background: #0b1220;
  }

  .site-footer h2 {
    margin: 0 0 10px;
    color: #fff;
    font-size: 1.05rem;
  }

  .site-footer p {
    max-width: 560px;
    margin: 8px 0;
  }

  .site-footer .brand-logo-name,
  .site-footer .brand-logo-tag {
    color: #fff;
  }

  .footer-links {
    display: grid;
    gap: 8px;
  }

  .footer-links a {
    color: #d6e0ec;
  }

  .mobile-bottom-bar {
    position: fixed;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 120;
    min-height: 64px;
    justify-content: space-around;
    gap: 4px;
    padding: 8px 8px calc(8px + env(safe-area-inset-bottom));
    border-top: 1px solid var(--line);
    background: rgba(255, 255, 255, 0.96);
