---
import TemplateHead from "../components/TemplateHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { getLanguageAlternates, getLocale, localePath } from "../i18n/index.js";
import { uiTranslations } from "../i18n/ui.js";

const {
  title,
  description,
  canonicalPath,
  robots = "index, follow",
  ogImage,
  ogType = "website",
  jsonLd,
  productAssets = false
} = Astro.props;

const locale = getLocale(Astro.url.pathname);
const languageAlternates = getLanguageAlternates(Astro.url.pathname);
const localizedCanonicalPath = canonicalPath === null ? null : localePath(canonicalPath || Astro.url.pathname, locale);
const translations = uiTranslations[locale] || uiTranslations.ru;

const themeScripts = [
  "/assets/theme/assets/js/plugin/bootstrap.min.js",
  "/assets/theme/assets/js/plugin/jquery.min.js",
  "/assets/theme/assets/js/plugin/swiper-bundle.min.js",
  "/assets/theme/assets/js/plugin/bootstrap-select.min.js",
  "/assets/theme/assets/js/plugin/count-down.js",
  "/assets/theme/assets/js/plugin/infinityslide.js",
  "/assets/theme/assets/js/carousel.js",
  "/assets/theme/assets/js/main.js",
  ...(productAssets
      ? [
        "/assets/theme/assets/js/plugin/drift.min.js",
        "/assets/theme/assets/js/plugin/photoswipe-lightbox.umd.min.js",
        "/assets/theme/assets/js/plugin/photoswipe.umd.min.js",
        "/assets/theme/assets/js/zoom.js"
      ]
    : [])
];

const themeLoader = `
(function () {
  var scripts = ${JSON.stringify(themeScripts)};
  var loaded = false;

  function loadScript(src) {
    return new Promise(function (resolve) {
      var script = document.createElement("script");
      script.src = src;
      script.onload = resolve;
      script.onerror = resolve;
      document.body.appendChild(script);
    });
  }

  function loadThemeScripts() {
    if (loaded) return;
    loaded = true;
    scripts.reduce(function (chain, src) {
      return chain.then(function () {
        return loadScript(src);
      });
    }, Promise.resolve());
  }

  function scheduleThemeScripts() {
    loadThemeScripts();
  }

  if (document.readyState === "complete") {
    scheduleThemeScripts();
  } else {
    window.addEventListener("load", scheduleThemeScripts, { once: true });
  }
})();
`;
---
<!doctype html>
<html lang={locale}>
  <head>
    <TemplateHead
      title={title}
      description={description}
      canonicalPath={localizedCanonicalPath}
      robots={robots}
      ogImage={ogImage}
      ogType={ogType}
      jsonLd={jsonLd}
      productAssets={productAssets}
      locale={locale}
      languageAlternates={languageAlternates}
    />
  </head>
  <body>
    <noscript>
      <div>
        <img src="https://mc.yandex.ru/watch/110354796" style="position:absolute; left:-9999px;" alt="" />
      </div>
    </noscript>
    <button id="goTop">
      <span class="border-progress"></span>
      <span class="ic-wrap">
        <span class="icon icon-CaretTopThin"></span>
      </span>
    </button>
    <main id="wrapper">
      <Header locale={locale} />
      <slot />
      <Footer locale={locale} />
    </main>
    <script is:inline src="/assets/theme/assets/js/wishlist-local.js"></script>
    <script is:inline define:vars={{ locale, translations }}>
      (function () {
        var supported = ["ru", "uz", "en"];
        var excludedPrefixes = ["/assets/", "/favicon", "/sitemap", "/robots"];

        function localizedUrl(value) {
          if (!value || value[0] !== "/" || value.startsWith("//")) return value;
          if (excludedPrefixes.some(function (prefix) { return value.startsWith(prefix); })) return value;
          var parts = value.split("/");
          if (supported.includes(parts[1])) parts.splice(1, 1);
          var path = parts.join("/") || "/";
          return "/" + locale + (path === "/" ? "/" : path);
        }

        function translateText(root) {
          var walker = document.createTreeWalker(root, NodeFilter.SHOW_TEXT);
          var nodes = [];
          while (walker.nextNode()) nodes.push(walker.currentNode);
          nodes.forEach(function (node) {
            if (node.parentElement && ["SCRIPT", "STYLE"].includes(node.parentElement.tagName)) return;
            var value = node.nodeValue || "";
            var trimmed = value.trim();
            if (trimmed && translations[trimmed]) {
              node.nodeValue = value.replace(trimmed, translations[trimmed]);
              return;
            }
            if (locale === "uz") {
              node.nodeValue = value
                .replace(/(\d+) товаров/g, "$1 ta mahsulot")
                .replace(/Найдено:\s*(\d+)/g, "$1 ta topildi")
                .replace(/По запросу «(.+?)» ничего не найдено\./g, "«$1» so‘rovi bo‘yicha hech narsa topilmadi.");
            } else if (locale === "en") {
              node.nodeValue = value
                .replace(/(\d+) товаров/g, "$1 products")
                .replace(/Найдено:\s*(\d+)/g, "$1 found")
                .replace(/По запросу «(.+?)» ничего не найдено\./g, "No results found for “$1”.");
            }
          });
        }

        function localize(root) {
          if (root.nodeType !== Node.ELEMENT_NODE && root !== document) return;
          translateText(root);
          root.querySelectorAll("a[href]:not([hreflang])").forEach(function (link) {
            link.setAttribute("href", localizedUrl(link.getAttribute("href")));
          });
          root.querySelectorAll("form[action]").forEach(function (form) {
            form.setAttribute("action", localizedUrl(form.getAttribute("action")));
          });
          root.querySelectorAll("[placeholder], [aria-label], [title]").forEach(function (element) {
            ["placeholder", "aria-label", "title"].forEach(function (attribute) {
              var value = element.getAttribute(attribute);
              if (!value) return;
              if (translations[value]) {
                element.setAttribute(attribute, translations[value]);
                return;
              }
              if (locale === "uz") {
                element.setAttribute(attribute, value
                  .replace(/^Добавить в избранное:/, "Sevimlilarga qo‘shish:")
                  .replace(/^Быстрый просмотр:/, "Tezkor ko‘rish:")
                  .replace(/^Смотреть товар:/, "Mahsulotni ko‘rish:"));
              } else if (locale === "en") {
                element.setAttribute(attribute, value
                  .replace(/^Добавить в избранное:/, "Add to wishlist:")
                  .replace(/^Быстрый просмотр:/, "Quick view:")
                  .replace(/^Смотреть товар:/, "View product:"));
              }
            });
          });
        }

        localize(document);
        new MutationObserver(function (mutations) {
          mutations.forEach(function (mutation) {
            mutation.addedNodes.forEach(localize);
          });
        }).observe(document.body, { childList: true, subtree: true });
      })();
    </script>
    <script is:inline set:html={themeLoader}></script>
  </body>
</html>
