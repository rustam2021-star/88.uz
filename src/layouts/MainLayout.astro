---
import TemplateHead from "../components/TemplateHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const { title, description } = Astro.props;
---
<!doctype html>
<html lang="ru">
  <head>
    <TemplateHead title={title} description={description} />
  </head>
  <body>
    <noscript>
      <div>
        <img src="https://mc.yandex.ru/watch/110354796" style="position:absolute; left:-9999px;" alt="" />
      </div>
    </noscript>
    <button id="goTop">
      <span class="border-progress"></span>
      <span class="ic-wrap">
        <span class="icon icon-CaretTopThin"></span>
      </span>
    </button>
    <div class="preload preload-container" id="preload">
      <div class="preload-logo">
        <div class="spinner"></div>
      </div>
    </div>
    <main id="wrapper">
      <Header />
      <slot />
      <Footer />
    </main>
    <script is:inline src="/assets/theme/assets/js/plugin/bootstrap.min.js"></script>
    <script is:inline src="/assets/theme/assets/js/plugin/jquery.min.js"></script>
    <script is:inline src="/assets/theme/assets/js/plugin/swiper-bundle.min.js"></script>
    <script is:inline src="/assets/theme/assets/js/plugin/bootstrap-select.min.js"></script>
    <script is:inline src="/assets/theme/assets/js/plugin/drift.min.js"></script>
    <script is:inline src="/assets/theme/assets/js/plugin/infinityslide.js"></script>
    <script is:inline src="/assets/theme/assets/js/plugin/count-down.js"></script>
    <script is:inline src="/assets/theme/assets/js/plugin/wow.min.js"></script>
    <script is:inline src="/assets/theme/assets/js/carousel.js"></script>
    <script is:inline src="/assets/theme/assets/js/main.js"></script>
    <script is:inline src="/assets/theme/assets/js/wishlist-local.js"></script>
    <script is:inline src="/assets/theme/assets/js/zoom.js"></script>
    <script is:inline src="/assets/theme/assets/js/plugin/photoswipe-lightbox.umd.min.js"></script>
    <script is:inline src="/assets/theme/assets/js/plugin/photoswipe.umd.min.js"></script>
  </body>
</html>
