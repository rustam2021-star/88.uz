---
import { getLocale } from "../i18n/index.js";
const locale = getLocale(Astro.url.pathname);
const itemSets = { ru: [
  { icon: "icon-Headset", title: "Консультация", text: "Поможем уточнить наличие, цену и комплектацию товара." },
  { icon: "icon-Package", title: "Получение", text: "Доставка или самовывоз согласуются индивидуально." },
  { icon: "icon-SealPercent", title: "Актуальные цены", text: "Цены указаны в сумах и подтверждаются перед заказом." },
  { icon: "icon-ArrowUDownLeft", title: "Проверка товара", text: "Проверяйте характеристики и инструкцию производителя." }
], uz: [
  { icon: "icon-Headset", title: "Maslahat", text: "Mahsulot mavjudligi, narxi va to‘plamini aniqlashga yordam beramiz." },
  { icon: "icon-Package", title: "Qabul qilish", text: "Yetkazib berish yoki olib ketish alohida kelishiladi." },
  { icon: "icon-SealPercent", title: "Amaldagi narxlar", text: "Narxlar so‘mda ko‘rsatilgan va buyurtmadan oldin tasdiqlanadi." },
  { icon: "icon-ArrowUDownLeft", title: "Mahsulotni tekshirish", text: "Xususiyatlar va ishlab chiqaruvchi yo‘riqnomasini tekshiring." }
], en: [
  { icon: "icon-Headset", title: "Consultation", text: "We’ll help confirm availability, price and what is included." },
  { icon: "icon-Package", title: "Pickup and delivery", text: "Delivery or pickup is arranged individually." },
  { icon: "icon-SealPercent", title: "Current prices", text: "Prices are shown in UZS and confirmed before ordering." },
  { icon: "icon-ArrowUDownLeft", title: "Product inspection", text: "Check the specifications and manufacturer’s instructions." }
] };
const items = itemSets[locale] || itemSets.ru;
---
<div class="flat-spacing">
  <div class="container">
    <div class="position-relative flat-spacing pb-0">
      <div class="br-line fake-class top-0"></div>
      <div class="swiper tf-swiper" data-mobile="1" data-mobile-sm="2" data-pagination="1" data-pagination-lg="4" data-pagination-md="3" data-pagination-sm="2" data-preview="4" data-space="10" data-space-lg="30" data-space-md="20" data-tablet="3" dir="ltr">
        <div class="swiper-wrapper">
          {items.map((item) => (
            <div class="swiper-slide">
              <div class="box-icon_V01 style-2 wow fadeInLeft">
                <span class="icon"><i class={item.icon}></i></span>
                <div class="content">
                  <h5 class="title">{item.title}</h5>
                  <p class="text cl-text-2">{item.text}</p>
                </div>
              </div>
            </div>
          ))}
        </div>
        <div class="sw-line-default style-2 tf-sw-pagination"></div>
      </div>
    </div>
  </div>
</div>
