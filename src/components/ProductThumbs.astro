---
import { CATALOG_URL, formatPrice, getImageSrcset, getImageVariant, getOrderUrl, getProductCardImage, getProductImage } from "../lib/catalog.js";
import products from "../data/products.json";

const slides = products.slice(0, 4).map((product) => ({
  image: product.gallery?.[0] || getProductImage(product),
  thumb: product.gallery?.[0] || getProductImage(product),
  product,
  name: product.title,
  price: formatPrice(product.price, product.currency),
  oldPrice: product.old_price ? formatPrice(product.old_price, product.currency) : ""
}));
---
<section class="themesFlat">
  <div class="container">
    <div class="banner-thumbs-product slider-thumb-wrap">
      <div class="col-left text-center flat-spacing">
        <div class="sect-heading type-2 wow fadeInUp">
          <h3 class="s-title">
            Точные приборы <br class="d-none d-xl-block" />
            для работы и дома
          </h3>
          <p class="s-desc text-body-1 cl-text-2">
            Измерительные инструменты, детекторы и полезное оборудование из актуального ассортимента.
          </p>
        </div>
        <div class="img-list wow fadeInUp">
          {slides.map((slide, index) => (
            <div class={`img_item btn-thumbs cs-pointer ${index === 0 ? "active" : ""}`}>
              <img
                alt={`${slide.name}, миниатюра`}
                height="120"
                loading="lazy"
                sizes="120px"
                src={getImageVariant(slide.thumb, 160)}
                srcset={getImageSrcset(slide.thumb, [88, 160])}
                width="120"
              />
            </div>
          ))}
        </div>
        <div class="wow fadeInUp">
          <a class="tf-btn animate-btn" href={CATALOG_URL}>
            Смотреть все товары
          </a>
        </div>
      </div>
      <div class="col-right">
        <div class="swiper slider-content-thumb swiper-tesimonial" dir="ltr">
          <div class="swiper-wrapper">
            {slides.map((slide) => (
              <div class="swiper-slide">
                <div class="wg-thumb-v1">
                  <div class="thumb-image">
                    <img
                      alt={`${slide.name}, обзор товара`}
                      height="546"
                      loading="lazy"
                      sizes="(max-width: 767px) 90vw, 440px"
                      src={getImageVariant(slide.image, 440)}
                      srcset={getImageSrcset(slide.image, [330, 440, 705])}
                      width="705"
                    />
                  </div>
                  <div class="thumb-prd">
                    <div class="prd_image">
                      <img alt={`${slide.name}, фото товара`} height="88" loading="lazy" sizes="88px" src={getProductCardImage(slide.product, 88)} srcset={getImageSrcset(getProductImage(slide.product), [88, 160])} width="88" />
                    </div>
                    <div class="prd_info">
                      <a class="name fw-medium link lh-24 text-line-clamp-2" href={`/product/${slide.product.slug}/`}>
                        {slide.name}
                      </a>
                      <div class="price-wrap">
                        <span class="price-new text-primary fw-semibold">{slide.price}</span>
                        {slide.oldPrice && <span class="price-old text-caption-01 cl-text-3">{slide.oldPrice}</span>}
                      </div>
                    </div>
                    <a
                      aria-label={`Заказать ${slide.name} в Telegram`}
                      class="btn-action hover-tooltip"
                      href={getOrderUrl(slide.product)}
                      rel="noopener"
                      target="_blank"
                    >
                      <span class="tooltip">Заказать</span>
                      <i class="icon icon-Handbag"></i>
                    </a>
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .banner-thumbs-product .col-right {
    background: #f8f8f8;
  }

  .banner-thumbs-product .slider-content-thumb,
  .banner-thumbs-product :global(.swiper-wrapper),
  .banner-thumbs-product :global(.swiper-slide),
  .banner-thumbs-product :global(.wg-thumb-v1) {
    height: 100%;
  }

  .banner-thumbs-product :global(.thumb-image) {
    display: flex;
    min-height: 560px;
    align-items: center;
    justify-content: center;
    padding: 42px 52px 92px;
  }

  .banner-thumbs-product :global(.thumb-image img) {
    width: min(76%, 500px) !important;
    height: auto !important;
    max-height: 460px;
    aspect-ratio: auto !important;
    object-fit: contain !important;
    transform: none !important;
  }

  .banner-thumbs-product :global(.thumb-prd) {
    left: 32px;
    right: 32px;
    bottom: 24px;
    width: fit-content;
    max-width: calc(100% - 64px);
    box-shadow: 0 12px 30px rgba(16, 16, 16, 0.08);
  }

  @media (max-width: 1199px) {
    .banner-thumbs-product :global(.thumb-image) {
      min-height: 460px;
      padding: 32px 36px 96px;
    }

    .banner-thumbs-product :global(.thumb-image img) {
      width: min(72%, 420px) !important;
      min-height: 0 !important;
      max-height: 360px;
    }
  }

  @media (max-width: 575px) {
    .banner-thumbs-product :global(.thumb-image) {
      min-height: 420px;
      padding: 24px 20px 150px;
    }

    .banner-thumbs-product :global(.thumb-image img) {
      width: min(82%, 320px) !important;
      max-height: 280px;
    }

    .banner-thumbs-product :global(.thumb-prd) {
      left: 20px;
      right: 20px;
      max-width: calc(100% - 40px);
    }
  }
</style>
