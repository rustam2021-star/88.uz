---
const { compact = false, id = "brand-logo" } = Astro.props;
const accentGradient = `${id}-accent`;
const glowFilter = `${id}-glow`;
---

<span class:list={["brand-logo", compact && "brand-logo--compact"]} aria-hidden="true">
  <svg class="brand-logo-mark" viewBox="0 0 180 64" role="img">
    <defs>
      <linearGradient id={accentGradient} x1="8" y1="12" x2="170" y2="52" gradientUnits="userSpaceOnUse">
        <stop offset="0" stop-color="#7dd3fc" />
        <stop offset="0.52" stop-color="#0ea5e9" />
        <stop offset="1" stop-color="#22c55e" />
      </linearGradient>
      <filter id={glowFilter} x="-20%" y="-20%" width="140%" height="140%">
        <feGaussianBlur stdDeviation="1.5" result="blur" />
        <feMerge>
          <feMergeNode in="blur" />
          <feMergeNode in="SourceGraphic" />
        </feMerge>
      </filter>
    </defs>
    <g transform="translate(1 1) rotate(-2 90 32) skewX(-4)">
      <rect x="4" y="10" width="170" height="44" rx="10" fill="#020617" filter={`url(#${glowFilter})`} />
      <rect x="8" y="14" width="162" height="36" rx="7" fill="#f8fafc" />
      <rect x="9" y="15" width="160" height="34" rx="6" fill="none" stroke="#0f172a" stroke-width="1.4" />
      <rect x="145" y="17" width="21" height="30" rx="4" fill="#0ea5e9" />
      <rect x="149" y="21" width="13" height="4" rx="1" fill="#38bdf8" />
      <rect x="149" y="26" width="13" height="1.4" fill="#dc2626" opacity="0.75" />
      <rect x="149" y="28.2" width="13" height="3.8" rx="1" fill="#22c55e" />
      <path d="M16 45h122" fill="none" stroke="#0ea5e9" stroke-width="1.8" stroke-linecap="round" opacity="0.45" />
      <text
        x="15"
        y="39"
        font-family="Space Grotesk, Arial, sans-serif"
        font-size="19"
        font-weight="900"
        letter-spacing="0.2"
        fill="#020617"
      >01</text>
      <text
        x="44"
        y="39"
        font-family="Space Grotesk, Arial, sans-serif"
        font-size="19"
        font-weight="900"
        letter-spacing="-0.1"
        fill="#020617"
      >O</text>
      <text
        x="68"
        y="41"
        font-family="Space Grotesk, Arial, sans-serif"
        font-size="30"
        font-weight="900"
        letter-spacing="-1.2"
        fill="#020617"
      >088</text>
      <text
        x="155.5"
        y="41"
        text-anchor="middle"
        font-family="Space Grotesk, Arial, sans-serif"
        font-size="10"
        font-weight="900"
        letter-spacing="0.8"
        fill="#fff"
      >UZ</text>
    </g>
  </svg>
  <span class="brand-logo-text">
    <span class="brand-logo-name">88<span>.uz</span></span>
    <span class="brand-logo-tag">tools delivery</span>
  </span>
</span>
