---
import { getLocale } from "../i18n/index.js";
const locale = getLocale(Astro.url.pathname);
const faqSets = { ru: [
  { question: "Как оформить заказ?", answer: "Выберите товар и нажмите “Заказать”, чтобы написать продавцу в Telegram." },
  { question: "Как быстро доставляете?", answer: "Срок и способ получения согласуются с продавцом перед заказом." },
  { question: "Можно ли вернуть товар?", answer: "Условия возврата и проверки товара нужно уточнить до оплаты." },
  { question: "Есть ли поддержка?", answer: "Да, можно написать в Telegram или позвонить по телефону из шапки сайта." },
  { question: "Как узнать наличие?", answer: "Актуальное наличие, цену и комплектацию лучше подтвердить перед заказом." }
], uz: [
  { question: "Qanday buyurtma beriladi?", answer: "Mahsulotni tanlang va Telegram’da sotuvchiga yozish uchun “Buyurtma berish” tugmasini bosing." },
  { question: "Yetkazib berish qancha vaqt oladi?", answer: "Olish muddati va usuli buyurtmadan oldin sotuvchi bilan kelishiladi." },
  { question: "Mahsulotni qaytarish mumkinmi?", answer: "Qaytarish va tekshirish shartlarini to‘lovdan oldin aniqlang." },
  { question: "Yordam xizmati bormi?", answer: "Telegram’da yozishingiz yoki saytdagi raqamga qo‘ng‘iroq qilishingiz mumkin." },
  { question: "Mavjudligini qanday bilaman?", answer: "Buyurtmadan oldin mavjudligi, narxi va to‘plamini tasdiqlang." }
], en: [
  { question: "How do I place an order?", answer: "Choose a product and click “Order” to message the seller on Telegram." },
  { question: "How quickly do you deliver?", answer: "Timing and delivery method are agreed with the seller before ordering." },
  { question: "Can I return a product?", answer: "Confirm return and inspection terms before payment." },
  { question: "Is support available?", answer: "Message us on Telegram or call the number in the site header." },
  { question: "How can I check availability?", answer: "Confirm current availability, price and included items before ordering." }
] };
const faqs = faqSets[locale] || faqSets.ru;
---
<section class="themesFlat">
  <div class="container">
    <div class="row">
      <div class="col-lg-6">
        <div class="sect-heading type-3 wow fadeInUp">
          <h2 class="h1 s-title font-red_hat fw-semibold letter-space-0">
            Есть вопрос? <br />
            Мы рядом и готовы помочь.
          </h1>
          <p class="s-desc text-body-1 cl-text-2">
            Посмотрите ответы на частые вопросы покупателей. <br />
            Остались вопросы?
          </p>
          <a class="tf-btn animate-btn" href="/catalog/">Купить сейчас</a>
        </div>
      </div>
      <div class="col-lg-6">
        <div class="d-grid gap-16" id="faq-accordion">
          {faqs.map((item, index) => {
            const id = `faq-${index + 1}`;
            const isOpen = index === 0;

            return (
              <div class="faq-accordion_item">
                <div
                  aria-controls={id}
                  aria-expanded={isOpen ? "true" : "false"}
                  class={`accordion-action h5 text-capitalize letter-space-05 ${isOpen ? "" : "collapsed"}`}
                  data-bs-target={`#${id}`}
                  data-bs-toggle="collapse"
                  role="button"
                >
                  <span>{item.question}</span>
                  <span class="icon ic-accordion-custom cl-2"></span>
                </div>
                <div class={`collapse ${isOpen ? "show" : ""}`} data-bs-parent="#faq-accordion" id={id}>
                  <p class="faq-content font-plus_jakarta text-body-1 cl-text-2">{item.answer}</p>
                </div>
              </div>
            );
          })}
        </div>
      </div>
    </div>
  </div>
</section>
