---
import ProductSlide from "./ProductSlide.astro";
import { STORE_PHONE, formatPrice, getImageSrcset, getImageVariant, getOrderUrl, getProductImage } from "../lib/catalog.js";

const { product, category, relatedProducts = [], recentlyProducts = [] } = Astro.props;
const price = formatPrice(product.price, product.currency);
const oldPrice = product.old_price ? formatPrice(product.old_price, product.currency) : "";
const gallery = product.gallery?.length ? product.gallery : [getProductImage(product)];
const related = relatedProducts.length ? relatedProducts : recentlyProducts;
const recently = recentlyProducts.length ? recentlyProducts : related;
const normalizeSpecValue = (key, value) => {
  const text = String(value ?? "").trim();

  if (key === "Состояние") {
    return text.replace(/\s*или\s+в\s+наличии\s+у\s+продавца/iu, "").trim() || "Новое";
  }

  if (key === "Город") {
    return text.split(",")[0]?.trim() || "Ташкент";
  }

  return text;
};

const specs = Object.entries(product.specs || {})
  .filter(([key]) => key !== "Источник")
  .map(([key, value]) => [key, normalizeSpecValue(key, value)]);
const condition = normalizeSpecValue("Состояние", product.condition || "Состояние уточняется");
const orderUrl = getOrderUrl(product);
const phoneUrl = `tel:${STORE_PHONE}`;
---

<div class="section-page-title-single flat-spacing-3">
  <div class="container">
    <div class="main-page-title">
      <div class="breadcrumbs">
        <a class="text-caption-01 cl-text-3 link" href="/">Главная</a>
        <i class="icon icon-CaretRightThin cl-text-3"></i>
        <a class="text-caption-01 cl-text-3 link" href={`/${category.slug}/`}>{category.title}</a>
        <i class="icon icon-CaretRightThin cl-text-3"></i>
        <p class="text-caption-01">{product.title}</p>
      </div>
      <div class="nav-post-list">
        <a class="link nav-post-item nav-post-prev" href={`/product/${recently[0]?.slug || product.slug}/`}><i class="icon icon-CaretLeft"></i></a>
        <a class="link nav-all-post nav-post-link" href={`/${category.slug}/`}><i class="icon icon-SquaresFour"></i></a>
        <a class="link nav-post-item nav-post-next" href={`/product/${recently[1]?.slug || product.slug}/`}><i class="icon icon-CaretRightThin"></i></a>
      </div>
    </div>
  </div>
</div>

<section class="section-product-single tf-main-product section-image-zoom">
  <div class="container">
    <div class="row">
      <div class="col-md-6">
        <div class="tf-product-media-wrap sticky-top">
          <div class="product-thumbs-slider style-row row_left">
            <div class="flat-wrap-media-product">
              <div class="swiper tf-product-media-main" data-spacing="0" dir="ltr" id="gallery-swiper-started">
                <div class="swiper-wrapper">
                  {gallery.map((image) => (
                    <div class="swiper-slide" data-color="default" data-size="default">
                      <a class="item" data-pswp-height="768px" data-pswp-width="576px" href={image} target="_blank">
                        <img alt="Товар" class="tf-image-zoom" data-zoom={image} height="768" loading="lazy" sizes="(max-width: 767px) 100vw, 576px" src={getImageVariant(image, 705)} srcset={getImageSrcset(image, [440, 705])} width="576" />
                      </a>
                    </div>
                  ))}
                </div>
              </div>
            </div>
            <div class="swiper tf-product-media-thumbs other-image-zoom" data-direction="vertical" data-preview="7" dir="ltr">
              <div class="swiper-wrapper stagger-wrap">
                {gallery.map((image) => (
                  <div class="swiper-slide stagger-item">
                    <div class="item">
                      <img alt="Изображение" height="110" loading="lazy" sizes="82px" src={getImageVariant(image, 88)} srcset={getImageSrcset(image, [88, 160])} width="82" />
                    </div>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="col-md-6">
        <div class="tf-product-info-wrap position-relative mt-md-0">
          <div class="tf-zoom-main sticky-top"></div>
          <div class="tf-product-info-list other-image-zoom">
            <div class="tf-product-info-heading">
              <p class="product-infor-cate text-caption-01 mb-4">{category.title}</p>
              <h3 class="product-infor-name mb-12">{product.title}</h3>
              <div class="product-infor-meta mb-20">
                <div class="meta_rate">
                  <span class="text-caption-01 cl-text-2">{condition}</span>
                </div>
                <div class="br-line type-vertical"></div>
                <div class="meta_sold">
                  <i class="icon icon-Lightning text-primary"></i>
                  <span class="text-caption-01 cl-text-2">{product.in_stock ? "В наличии у продавца" : "Наличие уточняется"}</span>
                </div>
                <div class="br-line type-vertical"></div>
                <div class="meta_prd_code text-caption-01"><span class="cl-text-2">Код:</span><span>{product.source_id || product.id}</span></div>
              </div>
              <div class="product-infor-price mb-12">
                <h4 class="price-on-sale">{price}</h4>
                {oldPrice && <><div class="br-line type-vertical"></div><p class="cl-text-3 text-decoration-line-through">{oldPrice}</p></>}
                {product.badges?.[0] && <span class="badge-sale text-white fw-semibold text-caption-02">{product.badges[0]}</span>}
              </div>
              <p class="product-infor-desc cl-text-2 mb-12">{product.description}</p>
              <div class="product-infor-reality lh-24">
                <div class="ic d-flex"><i class="icon icon-Eye"></i></div>
                <span class="text-caption-01">Перед заказом уточните наличие, комплектацию и способ получения.</span>
              </div>
            </div>

            <div class="br-line"></div>
            <div class="tf-product-variant">
              <div class="variant-picker-item">
                <div class="variant-picker-label">
                  <div>Город: <span class="variant-picker-label-value fw-medium">Ташкент</span></div>
                </div>
              </div>
              <div class="tf-product-total-quantity">
                <p>Количество:</p>
                <div class="group-action">
                  <div class="wg-quantity">
                    <button class="btn-quantity btn-decrease"><i class="icon icon-minus"></i></button>
                    <input class="quantity-product" name="number" type="text" value="1" />
                    <button class="btn-quantity btn-increase"><i class="icon icon-plus"></i></button>
                  </div>
                  <a class="btn-action-price tf-btn type-xl animate-btn w-100" href={orderUrl} rel="noopener" target="_blank">Заказать</a>
                </div>
                <a class="tf-btn type-xl btn-primary animate-btn w-100" href={phoneUrl}>Позвонить продавцу</a>
              </div>
            </div>

            <div class="tf-product-extra-link">
              <a class="product-extra-icon link" href={orderUrl} rel="noopener" target="_blank"><i class="icon icon-Question"></i>Задать вопрос</a>
              <a class="product-extra-icon link" data-bs-toggle="modal" href="#share"><i class="icon icon-ShareNetwork"></i>Поделиться</a>
            </div>
            <div class="br-line"></div>
            <div class="tf-product-delivery-return">
              <div class="product-delivery"><i class="icon icon-Timer"></i><p>Доставка и получение: <span class="fw-semibold">по договоренности</span>, условия уточняются перед заказом.</p></div>
              <div class="product-delivery return"><i class="icon icon-ArrowClockwise"></i><p>Проверяйте характеристики, комплектацию и инструкцию производителя перед покупкой.</p></div>
            </div>
            <div class="tf-product-trust-seal">
              <p class="h6 text-seal">Безопасная покупка:</p>
              <p class="text-caption-01 cl-text-2">Наличие, цену и условия передачи товара нужно подтвердить перед оплатой.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="section-product-description flat-spacing flat-animate-tab">
  <div class="container">
    <ul class="tab-btn-wrap-v1" role="tablist">
      <li class="nav-tab-item" role="presentation"><a class="tf-btn-tab active" data-bs-toggle="tab" href="#description" role="tab"><span class="h5 fw-medium">Описание</span></a></li>
      <li class="nav-tab-item" role="presentation"><a class="tf-btn-tab" data-bs-toggle="tab" href="#customer-reviews" role="tab"><span class="h5 fw-medium">Характеристики</span></a></li>
      <li class="nav-tab-item" role="presentation"><a class="tf-btn-tab" data-bs-toggle="tab" href="#shipping-returns" role="tab"><span class="h5 fw-medium">Заказ</span></a></li>
    </ul>
    <div class="tab-content">
      <div class="tab-pane active show" id="description" role="tabpanel">
        <div class="tab-content_desc tf-grid-layout md-col-2">
          <div class="box-desc"><h5 class="desc_title">{product.model}</h5><div class="desc_info"><p class="cl-text-2">{product.description}</p><p class="cl-text-2">{product.short_description}</p></div></div>
          <div class="box-desc"><h5 class="desc_title">Категория</h5><p class="cl-text-2">{category.description_top}</p><p class="cl-text-2">{category.description_bottom}</p></div>
        </div>
      </div>
      <div class="tab-pane" id="customer-reviews" role="tabpanel">
        <div class="tab-content_desc tf-grid-layout md-col-2">
          <div class="box-desc"><h5 class="desc_title">Характеристики</h5><ul class="list">{specs.map(([key, value]) => <li class="cl-text-2">- {key}: {value}</li>)}</ul></div>
        </div>
      </div>
      <div class="tab-pane" id="shipping-returns" role="tabpanel">
        <div class="tab-content_desc desc-2 tf-grid-layout sm-col-2 xl-col-4">
          <div class="box-desc"><h5 class="desc_title">Как заказать</h5><p class="cl-text-2">Нажмите “Заказать” и напишите продавцу в Telegram. Уточните наличие, цену и комплектацию.</p></div>
          <div class="box-desc"><h5 class="desc_title">Доставка</h5><p class="cl-text-2">Способ получения и сроки доставки согласуются индивидуально.</p></div>
        </div>
      </div>
    </div>
  </div>
</section>

<div class="flat-spacing flat-animate-tab pt-0">
  <div class="container">
    <ul class="tab-btn-wrap-v1 style-2 justify-content-sm-center" role="tablist">
      <li class="nav-tab-item" role="presentation"><a class="tf-btn-tab active" data-bs-toggle="tab" href="#related" role="tab"><span class="h4 fw-medium">Похожие товары</span></a></li>
      <li class="nav-tab-item" role="presentation"><a class="tf-btn-tab" data-bs-toggle="tab" href="#recently" role="tab"><span class="h4 fw-medium">Недавно смотрели</span></a></li>
    </ul>
    <div class="tab-content">
      <div class="tab-pane active show" id="related" role="tabpanel"><div class="swiper tf-swiper wrap-sw-over" data-mobile="2" data-mobile-sm="2" data-pagination="2" data-pagination-lg="4" data-pagination-md="3" data-pagination-sm="2" data-preview="4" data-space="10" data-space-lg="30" data-space-md="20" data-tablet="3" dir="ltr"><div class="swiper-wrapper">{related.slice(0, 4).map((item) => <ProductSlide product={item} />)}</div><div class="sw-line-default style-2 tf-sw-pagination"></div></div></div>
      <div class="tab-pane" id="recently" role="tabpanel"><div class="swiper tf-swiper wrap-sw-over" data-mobile="2" data-mobile-sm="2" data-pagination="2" data-pagination-lg="4" data-pagination-md="3" data-pagination-sm="2" data-preview="4" data-space="10" data-space-lg="30" data-space-md="20" data-tablet="3" dir="ltr"><div class="swiper-wrapper">{recently.slice(0, 4).map((item) => <ProductSlide product={item} />)}</div><div class="sw-line-default style-2 tf-sw-pagination"></div></div></div>
    </div>
  </div>
</div>
