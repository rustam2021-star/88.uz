---
import categories from "../data/categories.json";
import { BLOG_URL } from "../lib/catalog.js";
---
<footer class="tf-footer footer-s2 type-reverse bg-dark">
  <div class="position-relative">
    <div class="br-line fake-class bg-white_10 top-0"></div>
    <div class="container">
      <div class="footer-inner flat-spacing-2">
        <div class="col-left">
          <div class="footer-col-block type-white footer-wrap-3 ms-0 mb-sm-0">
            <p class="footer-heading footer-heading-mobile text-white">88.UZ</p>
            <div class="tf-collapse-content">
              <p class="footer-desc cl-text-3 mb-16">
                Каталог измерительных приборов, детекторов, автоинструментов, электроники и оборудования.
              </p>
              <a class="tf-btn animate-btn" href="/catalog/">Смотреть каталог</a>
            </div>
          </div>
        </div>
        <div class="br-line type-vertical"></div>
        <div class="col-right">
          <div class="footer-col-block type-white footer-wrap-1 mx-xl-auto mb-sm-0">
            <p class="footer-heading footer-heading-mobile text-white">КАТАЛОГ</p>
            <div class="tf-collapse-content">
              <ul class="footer-menu-list">
                <li><a class="cl-text-3 link" href="/catalog/">Все товары</a></li>
                {categories.slice(0, 4).map((category) => (
                  <li><a class="cl-text-3 link" href={`/${category.slug}/`}>{category.title}</a></li>
                ))}
              </ul>
            </div>
          </div>
          <div class="footer-col-block type-white footer-wrap-2 mx-xl-auto mb-sm-0">
            <p class="footer-heading footer-heading-mobile text-white">РАЗДЕЛЫ</p>
            <div class="tf-collapse-content">
              <ul class="footer-menu-list">
                {categories.slice(4).map((category) => (
                  <li><a class="cl-text-3 link" href={`/${category.slug}/`}>{category.title}</a></li>
                ))}
                <li><a class="cl-text-3 link" href={BLOG_URL}>Блог</a></li>
                <li><a class="cl-text-3 link" href="/wishlist/">Избранное</a></li>
              </ul>
            </div>
          </div>
          <div class="footer-col-block type-white footer-wrap-4 mb-sm-0 xl-d-none">
            <p class="footer-heading footer-heading-mobile text-white">КОНТАКТЫ</p>
            <div class="tf-collapse-content">
              <p class="cl-text-3 mb-4">Ташкент, Узбекистан</p>
              <a class="text-white link h4 fw-medium mb-12" href="tel:+998977334483">+998 97 733 44 83</a>
              <a class="cl-text-3 link mb-12" href="https://t.me/Senditme" target="_blank" rel="noopener">@Senditme</a>
              <p class="cl-text-3">Наличие, цену и условия получения уточняйте перед заказом.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
  <div class="footer-inner-slide-text">
    <div class="container">
      <div class="infiniteSlide-footer-text">
        <div class="infiniteSlide-element">
          <div class="infiniteSlide infiniteSlide-wrapper" data-clone="3">
            <div class="infiniteSlide-slide">
              <p class="ft-text text-display text-white fw-semibold">88.UZ ОНЛАЙН КАТАЛОГ&nbsp;</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
  <div class="footer-bottom">
    <div class="container">
      <div class="inner-bottom position-relative">
        <div class="br-line fake-class bg-white_10 top-0"></div>
        <p class="text-nocopy cl-text-3">(c)2026 88.uz. Все права защищены.</p>
        <p class="cl-text-3">Заказ через Telegram или телефон.</p>
      </div>
    </div>
  </div>
</footer>
