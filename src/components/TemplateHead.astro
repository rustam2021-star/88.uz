---
import { absoluteUrl, DEFAULT_OG_IMAGE, getCanonicalUrl } from "../lib/seo.js";

const {
  title = "88.uz — измерительные приборы и товары в Ташкенте",
  description = "Каталог 88.uz в Ташкенте: измерительные приборы, детекторы, автоинструменты, электроника и оборудование.",
  canonicalPath,
  robots = "index, follow",
  ogImage = DEFAULT_OG_IMAGE,
  ogType = "website",
  jsonLd,
  productAssets = false
} = Astro.props;

const canonical = canonicalPath === null ? null : getCanonicalUrl(canonicalPath || Astro.url.pathname);
const absoluteOgImage = absoluteUrl(ogImage);
const serializedJsonLd = jsonLd ? JSON.stringify(jsonLd).replace(/</g, "\\u003c") : "";

const productStylesheets = productAssets
  ? [
      "/assets/theme/assets/css/drift-basic.min.css",
      "/assets/theme/assets/css/photoswipe.css"
    ]
  : [];

const stylesheets = [
  "/assets/theme/assets/css/bootstrap.min.css",
  "/assets/theme/assets/css/swiper-bundle.min.css",
  ...productStylesheets,
  "/assets/theme/assets/css/animate.css",
  "/assets/theme/assets/fonts/fonts.css",
  "/assets/theme/assets/icon/icomoon/style.css",
  "/assets/theme/assets/css/styles.css"
];
---
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
{canonical && <link rel="canonical" href={canonical} />}
<meta name="robots" content={robots} />
<script is:inline>
  (function () {
    var analyticsLoaded = false;

    function loadScript(src) {
      var script = document.createElement("script");
      script.async = true;
      script.src = src;
      document.head.appendChild(script);
    }

    function loadAnalytics() {
      if (analyticsLoaded) return;
      analyticsLoaded = true;

      window.dataLayer = window.dataLayer || [];
      window.gtag = window.gtag || function () { window.dataLayer.push(arguments); };
      window.gtag("js", new Date());
      window.gtag("config", "G-88QZEBN3GG");
      loadScript("https://www.googletagmanager.com/gtag/js?id=G-88QZEBN3GG");

      window.ym = window.ym || function () { (window.ym.a = window.ym.a || []).push(arguments); };
      window.ym.l = 1 * new Date();
      window.ym(110354796, "init", { ssr: true, webvisor: true, clickmap: true, ecommerce: "dataLayer", referrer: document.referrer, url: location.href, accurateTrackBounce: true, trackLinks: true });
      loadScript("https://mc.yandex.ru/metrika/tag.js?id=110354796");
    }

    function scheduleAnalytics() {
      var events = ["pointerdown", "keydown", "touchstart", "scroll"];
      var timer = window.setTimeout(loadAnalytics, 8000);

      function onFirstInteraction() {
        window.clearTimeout(timer);
        events.forEach(function (eventName) {
          window.removeEventListener(eventName, onFirstInteraction);
        });
        loadAnalytics();
      }

      events.forEach(function (eventName) {
        window.addEventListener(eventName, onFirstInteraction, { once: true, passive: true });
      });
    }

    if (document.readyState === "complete") {
      scheduleAnalytics();
    } else {
      window.addEventListener("load", scheduleAnalytics, { once: true });
    }
  })();
</script>
<title>{title}</title>
<meta name="description" content={description} />
<meta property="og:site_name" content="88.uz" />
<meta property="og:locale" content="ru_RU" />
<meta property="og:type" content={ogType} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonical || Astro.url.href} />
<meta property="og:image" content={absoluteOgImage} />
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={absoluteOgImage} />
{jsonLd && <script type="application/ld+json" set:html={serializedJsonLd}></script>}
<link rel="shortcut icon" href="/assets/theme/assets/images/logo/favicon.svg" />
<style is:inline>
  :root{--white:#fff;--black:#000;--primary:#B71C1C;--secondary:#70857A;--third:#FFEB8A;--text:#101010;--text-2:#696E73;--text-3:#B1B2B7;--bg:#F7F7F7;--line:#E9E9E9;--white-10:rgba(255,255,255,.1)}
  *,*::before,*::after{box-sizing:border-box}
  html{font-family:system-ui,-apple-system,"Segoe UI",Roboto,Arial,sans-serif;-webkit-text-size-adjust:100%;scroll-behavior:smooth}
  body{margin:0;color:var(--text);background:var(--white);font-size:16px;line-height:1.5}
  a{color:inherit;text-decoration:none}
  img{max-width:100%;height:auto;vertical-align:middle}
  ul,p,h1,h2,h3,h4,h5,h6{margin-top:0}
  button,input,select,textarea{font:inherit}
  .container{width:min(100% - 30px,1440px);margin-inline:auto}
  .container-full{width:min(100% - 30px,1770px);margin-inline:auto}
  .row{display:flex;flex-wrap:wrap;margin-inline:-15px}
  .row>*{width:100%;padding-inline:15px}
  .d-none{display:none!important}.d-flex{display:flex!important}
  .text-center{text-align:center!important}.text-white{color:#fff!important}
  .bg-dark{background-color:var(--text)!important}
  .fw-semibold{font-weight:600!important}.fw-medium{font-weight:500!important}
  .position-relative{position:relative!important}.overflow-hidden{overflow:hidden!important}
  .mb-12{margin-bottom:12px!important}.mb-20{margin-bottom:20px!important}.mb-32{margin-bottom:32px!important}
  .rounded-20{border-radius:20px}
  .tf-topbar{position:relative;z-index:20}
  .tf-header{position:relative;z-index:20;background:#fff}
  .box-nav-menu,.nav-icon-list{display:flex;align-items:center;gap:24px;list-style:none;margin:0;padding:0}
  .nav-icon-item,.btn-open-menu{min-width:44px;min-height:44px;display:flex;align-items:center;justify-content:center}
  .sub-menu,.offcanvas{display:none}
  .swiper{position:relative;overflow:hidden}
  .swiper-wrapper{display:flex;width:100%}
  .swiper-slide{flex:0 0 100%;width:100%}
  .slider-wrap{position:relative}
  .sld_image img{display:block;width:100%;object-fit:cover}
  .sld_content{position:absolute;z-index:2;left:clamp(24px,6vw,110px);top:50%;transform:translateY(-50%);max-width:560px}
  .h1{font-size:clamp(34px,5vw,76px);line-height:1.05;font-weight:600}
  .text-body-1{font-size:16px;line-height:1.6}
  .tf-btn{display:inline-flex;align-items:center;justify-content:center;min-height:44px;padding:12px 24px;border-radius:999px;font-weight:600;background:var(--text);color:#fff}
  .btn-white{background:#fff;color:var(--text)}
  #goTop,.preload{display:none}
  @media (min-width:576px){.d-sm-block{display:block!important}}
  @media (min-width:1200px){.d-xl-flex{display:flex!important}.d-xl-none{display:none!important}.container{width:min(100% - 60px,1440px)}.container-full{width:min(100% - 60px,1770px)}}
  @media (max-width:1199px){.d-xl-none{display:block!important}.header-center{display:none!important}}
  @media (max-width:767px){.sld_content{left:20px;right:20px;top:auto;bottom:48px;transform:none}.h1{font-size:36px}}
</style>
{stylesheets.map((href) => (
  <link rel="stylesheet" href={href} />
))}
