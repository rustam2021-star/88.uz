---
import { getLocalizedCategories } from "../lib/content.js";
import { BLOG_URL, CATALOG_URL, STORE_PHONE } from "../lib/catalog.js";
import { languageNames, localePath, locales } from "../i18n/index.js";

const { locale = "ru" } = Astro.props;
const categories = getLocalizedCategories(locale);
const currentPath = Astro.url.pathname;
const homeUrl = localePath("/", locale);
const catalogUrl = localePath(CATALOG_URL, locale);
const blogUrl = localePath(BLOG_URL, locale);
const wishlistUrl = localePath("/wishlist/", locale);
const topbarText = locale === "en"
  ? "Special offers on measuring instruments and equipment — confirm availability before ordering"
  : locale === "uz"
    ? "O‘lchash asboblari va uskunalar uchun maxsus takliflar — buyurtmadan oldin mavjudligini aniqlang"
    : "Спецпредложения на измерительные приборы и оборудование - уточняйте наличие перед заказом";

const primaryCategories = categories.slice(0, 4);
const secondaryCategories = categories.slice(4);
---
<div class="tf-topbar topbar-construction bg-dark">
  <div class="container">
    <p class="topbar-text text-center text-white fw-semibold">
      {topbarText}
    </p>
  </div>
</div>

<header class="tf-header header-s2 header-construction">
  <div class="container">
    <div class="header-inner">
      <div class="box-open-menu-mobile d-xl-none">
        <a class="btn-open-menu" data-bs-toggle="offcanvas" href="#mobileMenu" aria-label="Открыть меню">
          <i class="icon icon-List"></i>
        </a>
      </div>

      <div class="header-left">
        <a href={homeUrl} class="logo-site">
          <img
            alt="88.uz"
            decoding="async"
            height="111"
            loading="eager"
            sizes="(max-width: 374px) 155px, (max-width: 575px) 170px, (max-width: 1199px) 210px, 260px"
            src="/assets/theme/assets/images/logo/logo-88uz-520.webp"
            srcset="/assets/theme/assets/images/logo/logo-88uz-340.webp 340w, /assets/theme/assets/images/logo/logo-88uz-520.webp 520w, /assets/theme/assets/images/logo/logo-88uz-780.webp 780w"
            width="520"
          />
        </a>
      </div>

      <nav class="header-center d-none d-xl-flex justify-content-center">
        <ul class="box-nav-menu">
          <li class="menu-item position-relative">
            <a class="item-link" href={homeUrl}>
              <span class="text cus-text">Главная</span>
              <i class="icon icon-CaretDown"></i>
            </a>
            <div class="sub-menu">
              <ul class="sub-menu_list">
                <li><a class="sub-menu_link has-text" href={homeUrl}><span class="cus-text">Главная страница</span></a></li>
                <li><a class="sub-menu_link has-text" href={catalogUrl}><span class="cus-text">Каталог товаров</span></a></li>
                <li><a class="sub-menu_link has-text" href={blogUrl}><span class="cus-text">Блог</span></a></li>
              </ul>
            </div>
          </li>

          <li class="menu-item">
            <a class="item-link" href={catalogUrl}>
              <span class="text cus-text">Магазин</span>
              <i class="icon icon-CaretDown"></i>
            </a>
            <div class="sub-menu mega-menu">
              <div class="container">
                <div class="row">
                  <div class="col-4">
                    <div class="mega-menu-item menu-lv-2">
                      <p class="menu-heading">Основные разделы</p>
                      <ul class="sub-menu_list">
                        {primaryCategories.map((category) => (
                          <li>
                            <a class="sub-menu_link has-text" href={localePath(`/${category.slug}/`, locale)}>
                              <span class="cus-text">{category.title}</span>
                            </a>
                          </li>
                        ))}
                      </ul>
                    </div>
                  </div>
                  <div class="col-4">
                    <div class="mega-menu-item menu-lv-2">
                      <p class="menu-heading">Дополнительно</p>
                      <ul class="sub-menu_list">
                        {secondaryCategories.map((category) => (
                          <li>
                            <a class="sub-menu_link has-text" href={localePath(`/${category.slug}/`, locale)}>
                              <span class="cus-text">{category.title}</span>
                            </a>
                          </li>
                        ))}
                      </ul>
                    </div>
                  </div>
                  <div class="col-4">
                    <div class="header-menu-preview">
                      <img alt="Оборудование 88.uz" height="240" loading="lazy" src="/assets/theme/assets/images/section/amerce-html.jpg" width="320" />
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </li>

          {primaryCategories.slice(1, 3).map((category) => (
            <li class="menu-item position-relative">
              <a class="item-link" href={localePath(`/${category.slug}/`, locale)}>
                <span class="text cus-text">{category.title}</span>
              </a>
            </li>
          ))}

          <li class="menu-item position-relative">
            <a class="item-link" href={blogUrl}>
              <span class="text cus-text">Блог</span>
              <i class="icon icon-CaretDown"></i>
            </a>
            <div class="sub-menu">
              <ul class="sub-menu_list">
                <li><a class="sub-menu_link has-text" href={blogUrl}><span class="cus-text">Все статьи</span></a></li>
                <li><a class="sub-menu_link has-text" href={localePath("/blog/kak-vybrat-izmeritelnyi-pribor/", locale)}><span class="cus-text">Как выбрать прибор</span></a></li>
                <li><a class="sub-menu_link has-text" href={localePath("/blog/teplovizor-dlya-diagnostiki/", locale)}><span class="cus-text">Тепловизоры</span></a></li>
              </ul>
            </div>
          </li>

          <li class="menu-item position-relative">
            <a class="item-link" href={catalogUrl}>
              <span class="text cus-text">Все товары</span>
            </a>
          </li>
        </ul>
      </nav>

      <div class="header-right">
        <ul class="nav-icon-list">
          <li>
            <nav class="language-switcher" aria-label="Язык">
              {locales.map((code) => (
                <a
                  aria-current={code === locale ? "page" : undefined}
                  class:list={["language-switcher_link", { active: code === locale }]}
                  href={localePath(currentPath, code)}
                  hreflang={code}
                  lang={code}
                  title={languageNames[code]}
                >{code.toUpperCase()}</a>
              ))}
            </nav>
          </li>
          <li>
            <a class="nav-icon-item link" data-bs-toggle="modal" href="#search" aria-label="Поиск">
              <i class="icon icon-MagnifyingGlass"></i>
            </a>
          </li>
          <li class="d-none d-sm-block">
            <a class="nav-icon-item link" href={wishlistUrl} aria-label="Избранное">
              <i class="icon icon-HeartStraight"></i>
            </a>
          </li>
        </ul>
      </div>
    </div>
  </div>
</header>

<div class="modal fade" id="search" tabindex="-1" aria-labelledby="searchTitle" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered"><div class="modal-content search-modal-content">
    <div class="modal-header"><h5 class="modal-title" id="searchTitle">Поиск товаров</h5><button class="btn-close" type="button" data-bs-dismiss="modal" aria-label="Закрыть"></button></div>
    <form class="form-search-nav search-modal-form" action={catalogUrl}>
      <div class="search-input-wrap"><i class="icon icon-MagnifyingGlass"></i><input name="q" placeholder="Например, тепловизор" required type="search" /></div>
      <button class="tf-btn btn-dark" type="submit">Найти</button>
    </form>
  </div></div>
</div>

<script is:inline>
  document.querySelectorAll("[data-language-switcher]").forEach(function (select) {
    select.addEventListener("change", function () {
      window.location.href = select.value;
    });
  });
</script>

<div class="offcanvas offcanvas-start canvas-mb" id="mobileMenu">
  <div class="canvas-header">
    <span class="icon-close-popup" data-bs-dismiss="offcanvas">
      <i class="icon icon-X2"></i>
    </span>
    <form class="form-search-nav" action={catalogUrl}>
      <fieldset>
        <input name="q" placeholder="Что вы ищете?" required type="search" />
      </fieldset>
      <button class="btn-action" type="submit">
        <i class="icon icon-MagnifyingGlass"></i>
      </button>
    </form>
  </div>
  <div class="canvas-body">
    <div class="mb-content-top">
      <ul class="nav-ul-mb">
        <li class="nav-mb-item"><a class="mb-menu-link" href={homeUrl}>Главная</a></li>
        <li class="nav-mb-item"><a class="mb-menu-link" href={catalogUrl}>Все товары</a></li>
        {categories.map((category) => (
          <li class="nav-mb-item"><a class="mb-menu-link" href={localePath(`/${category.slug}/`, locale)}>{category.title}</a></li>
        ))}
        <li class="nav-mb-item"><a class="mb-menu-link" href={blogUrl}>Блог</a></li>
      </ul>
    </div>
    <div class="need-help-wrap">
      <p class="nd-title h6 fw-medium mb-16">Нужна помощь?</p>
      <p class="lh-26 cl-text-2 mb-4">Ташкент, Узбекистан</p>
      <a class="cl-text-2 link mb-8" href="https://t.me/Senditme" rel="noopener" target="_blank">@Senditme</a>
      <a class="cl-text-2 link" href={`tel:${STORE_PHONE}`}>+998 97 733 44 83</a>
    </div>
  </div>
  <div class="canvas-footer">
    <div class="d-flex justify-content-center border-end">
      <div class="tf-currencies">
        <select class="tf-dropdown-select style-default type-currencies">
          <option selected>UZS сум</option>
          <option>USD $</option>
        </select>
      </div>
    </div>
    <div class="d-flex justify-content-center">
      <div class="tf-languages">
        <select aria-label="Язык" class="tf-dropdown-select style-default type-languages" data-language-switcher>
          {locales.map((code) => <option value={localePath(currentPath, code)} selected={code === locale}>{languageNames[code]}</option>)}
        </select>
      </div>
    </div>
  </div>
</div>

<style>
  .topbar-construction {
    padding: 12px 0;
  }

  .topbar-construction .topbar-text {
    margin-bottom: 0;
    font-size: 15px;
    line-height: 1.4;
  }

  .header-construction {
    background: var(--white);
    border-bottom: 1px solid var(--line);
  }

  .header-construction .header-inner {
    min-height: 90px;
    display: flex;
    align-items: center;
    gap: 24px;
  }

  .search-modal-content { padding: 8px; border-radius: 12px; }
  .search-modal-form { display: flex; gap: 12px; padding: 8px 16px 20px; }
  .search-input-wrap { flex: 1; display: flex; align-items: center; gap: 10px; border: 1px solid var(--line); padding: 0 14px; }
  .search-input-wrap input { width: 100%; border: 0; outline: 0; min-height: 48px; }
  @media (max-width: 575px) { .search-modal-form { flex-direction: column; } }

  .header-construction .header-left,
  .header-construction .header-right {
    flex: 1 1 0;
  }

  .language-switcher {
    display: inline-flex;
    align-items: center;
    min-height: 44px;
    padding: 3px;
    border: 1px solid var(--line);
    border-radius: 999px;
    background: var(--white);
  }

  .language-switcher_link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 38px;
    min-height: 36px;
    padding: 0 8px;
    border-radius: 999px;
    font-size: 13px;
    font-weight: 600;
    line-height: 1;
  }

  .language-switcher_link.active {
    color: var(--white);
    background: var(--text);
  }

  .language-switcher_link:focus-visible {
    outline: 2px solid var(--primary);
    outline-offset: 2px;
  }

  .header-construction .logo-site img {
    display: block;
    width: 260px;
    height: auto;
  }

  .header-construction .header-center {
    flex: 2 1 auto;
  }

  .header-construction .header-right {
    display: flex;
    justify-content: flex-end;
  }

  .header-construction .box-nav-menu {
    justify-content: center;
  }

  .header-construction .item-link {
    padding-top: 32px;
    padding-bottom: 32px;
  }

  .header-menu-preview {
    overflow: hidden;
    border-radius: 12px;
    background: var(--bg);
  }

  .header-menu-preview img {
    width: 100%;
    height: 240px;
    object-fit: cover;
  }

  @media (max-width: 1199px) {
    .header-construction .header-inner {
      min-height: 74px;
    }

    .header-construction .logo-site img {
      width: 210px;
    }
  }

  @media (max-width: 575px) {
    .topbar-construction {
      display: none;
    }

    .header-construction .logo-site img {
      width: 130px;
    }

    .header-construction .nav-icon-list {
      gap: 8px;
    }

    .language-switcher_link {
      min-width: 28px;
      padding-inline: 5px;
      font-size: 11px;
    }
  }

  @media (max-width: 374px) {
    .header-construction .logo-site img {
      width: 155px;
    }
  }
</style>
