---
import Logo from "./Logo.astro";
import TopBar from "./TopBar.astro";
import MobileHeader from "./MobileHeader.astro";
import { categoryUrl, getCategories, getProducts, productUrl, site } from "../lib/catalog";

const categories = getCategories();
const products = getProducts();
const desktopCategories = categories.slice(0, 7);
const phoneHref = `tel:${site.phone.replaceAll(" ", "")}`;
const searchItems = [
  ...categories.map((category) => ({
    type: "Категория",
    title: category.title,
    href: categoryUrl(category),
    meta: category.seo_description,
    search: [category.title, category.h1, category.seo_description, category.slug].join(" ")
  })),
  ...products.map((product) => ({
    type: "Товар",
    title: product.title,
    href: productUrl(product),
    meta: `${product.brand} ${product.model}`,
    search: [
      product.title,
      product.brand,
      product.model,
      product.short_description,
      product.description,
      product.category_slug,
      ...(product.keywords ?? [])
    ].join(" ")
  }))
];
---

<header class="site-header">
  <TopBar />

  <div class="header-main">
    <a class="brand" href="/" aria-label="88.uz">
      <Logo id="header-logo" />
    </a>

    <div class="desktop-search" data-search-root>
      <label class="sr-only" for="desktop-catalog-search">Поиск по каталогу</label>
      <div class="search-shell">
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="m21 21-4.3-4.3M10.8 18a7.2 7.2 0 1 1 0-14.4 7.2 7.2 0 0 1 0 14.4Z" />
        </svg>
        <input
          id="desktop-catalog-search"
          type="search"
          placeholder="Мультиметр, тепловизор, дальномер..."
          autocomplete="off"
          data-catalog-search
        />
        <button type="button" class="search-submit" data-search-submit>Поиск</button>
      </div>
      <div class="catalog-search-results" data-catalog-search-results hidden aria-live="polite"></div>
    </div>

    <div class="header-actions">
      <a class="header-action secondary" href={phoneHref}>Позвонить</a>
      <a class="header-action" href={site.telegram}>Telegram</a>
      <MobileHeader />
    </div>
  </div>

  <div class="search-row" id="site-search" data-search-root>
    <label class="sr-only" for="mobile-catalog-search">Поиск по каталогу</label>
    <div class="mobile-search-field">
      <svg viewBox="0 0 24 24" aria-hidden="true">
        <path d="m21 21-4.3-4.3M10.8 18a7.2 7.2 0 1 1 0-14.4 7.2 7.2 0 0 1 0 14.4Z" />
      </svg>
      <input
        id="mobile-catalog-search"
        type="search"
        placeholder="Найти товар..."
        autocomplete="off"
        data-catalog-search
      />
      <button type="button" class="search-submit" data-search-submit>Найти</button>
    </div>
    <div class="catalog-search-results" data-catalog-search-results hidden aria-live="polite"></div>
  </div>

  <div class="commerce-nav">
    <a class="browse-button" href="/#categories">Каталог</a>
    <nav class="main-nav" aria-label="Основная навигация">
      {desktopCategories.map((category) => (
        <a href={categoryUrl(category)}>{category.title}</a>
      ))}
    </nav>
    <a class="special-offer" href={site.telegram}>Заказать в Telegram</a>
  </div>

  <div class="mobile-menu-overlay" data-mobile-menu-close></div>

  <aside class="mobile-menu" id="mobile-menu" aria-hidden="true" aria-label="Мобильный каталог">
    <div>
      <p class="eyebrow">Каталог 88.uz</p>
      <strong>Выберите раздел или напишите в Telegram</strong>
    </div>
    <div class="mobile-category-list">
      {categories.map((category) => (
        <a href={categoryUrl(category)} data-mobile-menu-link>
          <span>{category.title}</span>
          <small>{category.seo_description}</small>
        </a>
      ))}
    </div>
    <div class="actions">
      <a class="button button-telegram" href={site.telegram} data-mobile-menu-link>Заказать в Telegram</a>
      <a class="button button-secondary" href={phoneHref} data-mobile-menu-link>Позвонить</a>
    </div>
  </aside>

  <script type="application/json" id="catalog-search-data" set:html={JSON.stringify(searchItems)} />
</header>

