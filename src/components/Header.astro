---
import categories from "../data/categories.json";
import { BLOG_URL, CATALOG_URL, STORE_PHONE } from "../lib/catalog.js";

const primaryCategories = categories.slice(0, 4);
const secondaryCategories = categories.slice(4);
---
<div class="tf-topbar topbar-construction bg-dark">
  <div class="container">
    <p class="topbar-text text-center text-white fw-semibold">
      Спецпредложения на измерительные приборы и оборудование - уточняйте наличие перед заказом
    </p>
  </div>
</div>

<header class="tf-header header-s2 header-construction">
  <div class="container">
    <div class="header-inner">
      <div class="box-open-menu-mobile d-xl-none">
        <a class="btn-open-menu" data-bs-toggle="offcanvas" href="#mobileMenu" aria-label="Открыть меню">
          <i class="icon icon-List"></i>
        </a>
      </div>

      <div class="header-left">
        <a href="/" class="logo-site">
          <img alt="88.uz" decoding="async" height="52" loading="eager" src="/assets/theme/assets/images/logo/logo.svg" width="260" />
        </a>
      </div>

      <nav class="header-center d-none d-xl-flex justify-content-center">
        <ul class="box-nav-menu">
          <li class="menu-item position-relative">
            <a class="item-link" href="/">
              <span class="text cus-text">Главная</span>
              <i class="icon icon-CaretDown"></i>
            </a>
            <div class="sub-menu">
              <ul class="sub-menu_list">
                <li><a class="sub-menu_link has-text" href="/"><span class="cus-text">Главная страница</span></a></li>
                <li><a class="sub-menu_link has-text" href={CATALOG_URL}><span class="cus-text">Каталог товаров</span></a></li>
                <li><a class="sub-menu_link has-text" href={BLOG_URL}><span class="cus-text">Блог</span></a></li>
              </ul>
            </div>
          </li>

          <li class="menu-item">
            <a class="item-link" href={CATALOG_URL}>
              <span class="text cus-text">Магазин</span>
              <i class="icon icon-CaretDown"></i>
            </a>
            <div class="sub-menu mega-menu">
              <div class="container">
                <div class="row">
                  <div class="col-4">
                    <div class="mega-menu-item menu-lv-2">
                      <p class="menu-heading">Основные разделы</p>
                      <ul class="sub-menu_list">
                        {primaryCategories.map((category) => (
                          <li>
                            <a class="sub-menu_link has-text" href={`/${category.slug}/`}>
                              <span class="cus-text">{category.title}</span>
                            </a>
                          </li>
                        ))}
                      </ul>
                    </div>
                  </div>
                  <div class="col-4">
                    <div class="mega-menu-item menu-lv-2">
                      <p class="menu-heading">Дополнительно</p>
                      <ul class="sub-menu_list">
                        {secondaryCategories.map((category) => (
                          <li>
                            <a class="sub-menu_link has-text" href={`/${category.slug}/`}>
                              <span class="cus-text">{category.title}</span>
                            </a>
                          </li>
                        ))}
                      </ul>
                    </div>
                  </div>
                  <div class="col-4">
                    <div class="header-menu-preview">
                      <img alt="Оборудование 88.uz" height="240" loading="lazy" src="/assets/theme/assets/images/section/amerce-html.jpg" width="320" />
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </li>

          {primaryCategories.slice(1, 3).map((category) => (
            <li class="menu-item position-relative">
              <a class="item-link" href={`/${category.slug}/`}>
                <span class="text cus-text">{category.title}</span>
              </a>
            </li>
          ))}

          <li class="menu-item position-relative">
            <a class="item-link" href={BLOG_URL}>
              <span class="text cus-text">Блог</span>
              <i class="icon icon-CaretDown"></i>
            </a>
            <div class="sub-menu">
              <ul class="sub-menu_list">
                <li><a class="sub-menu_link has-text" href={BLOG_URL}><span class="cus-text">Все статьи</span></a></li>
                <li><a class="sub-menu_link has-text" href="/blog/kak-vybrat-izmeritelnyi-pribor/"><span class="cus-text">Как выбрать прибор</span></a></li>
                <li><a class="sub-menu_link has-text" href="/blog/teplovizor-dlya-diagnostiki/"><span class="cus-text">Тепловизоры</span></a></li>
              </ul>
            </div>
          </li>

          <li class="menu-item position-relative">
            <a class="item-link" href={CATALOG_URL}>
              <span class="text cus-text">Все товары</span>
            </a>
          </li>
        </ul>
      </nav>

      <div class="header-right">
        <ul class="nav-icon-list">
          <li>
            <a class="nav-icon-item link" data-bs-toggle="modal" href="#search" aria-label="Поиск">
              <i class="icon icon-MagnifyingGlass"></i>
            </a>
          </li>
          <li class="d-none d-sm-block">
            <a class="nav-icon-item link" href="/wishlist/" aria-label="Избранное">
              <i class="icon icon-HeartStraight"></i>
            </a>
          </li>
        </ul>
      </div>
    </div>
  </div>
</header>

<div class="offcanvas offcanvas-start canvas-mb" id="mobileMenu">
  <div class="canvas-header">
    <span class="icon-close-popup" data-bs-dismiss="offcanvas">
      <i class="icon icon-X2"></i>
    </span>
    <form class="form-search-nav" action={CATALOG_URL}>
      <fieldset>
        <input placeholder="Что вы ищете?" required type="text" />
      </fieldset>
      <button class="btn-action" type="submit">
        <i class="icon icon-MagnifyingGlass"></i>
      </button>
    </form>
  </div>
  <div class="canvas-body">
    <div class="mb-content-top">
      <ul class="nav-ul-mb">
        <li class="nav-mb-item"><a class="mb-menu-link" href="/">Главная</a></li>
        <li class="nav-mb-item"><a class="mb-menu-link" href={CATALOG_URL}>Все товары</a></li>
        {categories.map((category) => (
          <li class="nav-mb-item"><a class="mb-menu-link" href={`/${category.slug}/`}>{category.title}</a></li>
        ))}
        <li class="nav-mb-item"><a class="mb-menu-link" href={BLOG_URL}>Блог</a></li>
      </ul>
    </div>
    <div class="need-help-wrap">
      <p class="nd-title h6 fw-medium mb-16">Нужна помощь?</p>
      <p class="lh-26 cl-text-2 mb-4">Ташкент, Узбекистан</p>
      <a class="cl-text-2 link mb-8" href="https://t.me/Senditme" rel="noopener" target="_blank">@Senditme</a>
      <a class="cl-text-2 link" href={`tel:${STORE_PHONE}`}>+998 97 733 44 83</a>
    </div>
  </div>
  <div class="canvas-footer">
    <div class="d-flex justify-content-center border-end">
      <div class="tf-currencies">
        <select class="tf-dropdown-select style-default type-currencies">
          <option selected>UZS сум</option>
          <option>USD $</option>
        </select>
      </div>
    </div>
    <div class="d-flex justify-content-center">
      <div class="tf-languages">
        <select class="tf-dropdown-select style-default type-languages">
          <option>Русский</option>
          <option>Uzbek</option>
          <option>English</option>
        </select>
      </div>
    </div>
  </div>
</div>

<style>
  .topbar-construction {
    padding: 12px 0;
  }

  .topbar-construction .topbar-text {
    margin-bottom: 0;
    font-size: 15px;
    line-height: 1.4;
  }

  .header-construction {
    background: var(--white);
    border-bottom: 1px solid var(--line);
  }

  .header-construction .header-inner {
    min-height: 90px;
    display: flex;
    align-items: center;
    gap: 24px;
  }

  .header-construction .header-left,
  .header-construction .header-right {
    flex: 1 1 0;
  }

  .header-construction .logo-site img {
    display: block;
    width: 260px;
    height: auto;
  }

  .header-construction .header-center {
    flex: 2 1 auto;
  }

  .header-construction .header-right {
    display: flex;
    justify-content: flex-end;
  }

  .header-construction .box-nav-menu {
    justify-content: center;
  }

  .header-construction .item-link {
    padding-top: 32px;
    padding-bottom: 32px;
  }

  .header-menu-preview {
    overflow: hidden;
    border-radius: 12px;
    background: var(--bg);
  }

  .header-menu-preview img {
    width: 100%;
    height: 240px;
    object-fit: cover;
  }

  @media (max-width: 1199px) {
    .header-construction .header-inner {
      min-height: 74px;
    }

    .header-construction .logo-site img {
      width: 210px;
    }
  }

  @media (max-width: 575px) {
    .topbar-construction {
      display: none;
    }

    .header-construction .logo-site img {
      width: 170px;
    }
  }

  @media (max-width: 374px) {
    .header-construction .logo-site img {
      width: 155px;
    }
  }
</style>
