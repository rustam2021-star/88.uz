---
import categories from "../data/categories.json";
---
<section class="section-categories-construction flat-spacing">
  <div class="container">
    <div class="sect-heading text-center wow fadeInUp">
      <h3 class="s-title">Категории товаров</h3>
      <p class="s-desc text-body-1 cl-text-2">
        Подберите приборы, детекторы и оборудование под вашу задачу.
      </p>
    </div>
    <div class="tf-grid-layout tf-col-2 sm-col-3 lg-col-4 xl-col-5">
      {categories.map((category) => (
        <a class="category-construction_item hover-img wow fadeInUp" href={`/${category.slug}/`}>
          <div class="cate-image img-style">
            <img alt={category.title} height="600" loading="lazy" src={category.image} width="600" />
          </div>
          <div class="cate-content text-center">
            <h4 class="cate_name link h5">{category.title}</h4>
            <p class="cate_quantity text-caption-01 cl-text-2">{category.quantity}</p>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .section-categories-construction .sect-heading {
    margin-bottom: 42px;
  }

  .category-construction_item {
    display: grid;
    place-items: center;
    text-align: center;
  }

  .category-construction_item .cate-image {
    width: min(100%, 220px);
    aspect-ratio: 1;
    border-radius: 50%;
    background: linear-gradient(145deg, #ffffff 0%, #f4f4f4 100%);
    border: 1px solid rgba(16, 16, 16, 0.06);
    box-shadow:
      0 14px 30px rgba(16, 16, 16, 0.06),
      inset 0 0 0 8px rgba(255, 255, 255, 0.45);
    overflow: hidden;
    margin-bottom: 18px;
  }

  .category-construction_item .cate-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transform: scale(1.01);
  }

  .category-construction_item .cate_name {
    margin-bottom: 6px;
  }

  @media (max-width: 575px) {
    .section-categories-construction .sect-heading {
      margin-bottom: 28px;
    }

    .category-construction_item .cate-image {
      width: min(100%, 160px);
    }
  }
</style>
