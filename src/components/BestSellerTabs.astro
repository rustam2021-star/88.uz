---
import ProductCard from "./ProductCard.astro";
import categories from "../data/categories.json";
import products from "../data/products.json";
import { getImageSrcset, getImageVariant } from "../lib/catalog.js";

const tabSlugs = ["measuring-tools", "thermal-detectors", "auto-service", "tools-equipment"];
const fallbackProducts = products.filter((product) => product.in_stock !== false);
const bannerImage = "/assets/theme/assets/images/section/banner-54.jpg";
const thermalImagerBannerImage = "/assets/theme/assets/images/section/banner-thermal-imager.webp";
const autoServiceBannerImage = "/assets/theme/assets/images/section/banner-auto-service-tpms.png";
const toolsEquipmentBannerImage = "/assets/theme/assets/images/section/banner-tools-equipment-laser-level.png";
const compactProductSizes = "(max-width: 575px) 46vw, (max-width: 991px) 30vw, 180px";

const tabCopy = {
  "measuring-tools": {
    title: "Точные приборы для работы",
    desc: "Измерение, диагностика и контроль для ремонта, дома и мастерской."
  },
  "thermal-detectors": {
    title: "Тепловизоры и детекторы",
    desc: "Поиск утечек, перегрева, скрытой проводки, газа и радиационного фона."
  },
  "auto-service": {
    title: "Автоинструменты",
    desc: "Тестеры, TPMS, UV-фонари и приборы для проверки автомобиля."
  },
  "tools-equipment": {
    title: "Инструменты и оборудование",
    desc: "Практичные решения для ремонта, монтажа и ежедневных задач."
  }
};

function getTabProducts(categorySlug) {
  const categoryProducts = fallbackProducts.filter((product) => product.category_slug === categorySlug);
  const extras = fallbackProducts.filter((product) => product.category_slug !== categorySlug);

  return [...categoryProducts, ...extras].slice(0, 8);
}

const tabs = tabSlugs
  .map((slug) => {
    const category = categories.find((item) => item.slug === slug);

    if (!category) {
      return null;
    }

    return {
      id: category.slug,
      label: category.title,
      url: `/${category.slug}/`,
      banner: tabCopy[category.slug] || {
        title: category.title,
        desc: category.description_top
      },
      bannerImage: category.slug === "thermal-detectors"
        ? thermalImagerBannerImage
        : category.slug === "tools-equipment"
          ? toolsEquipmentBannerImage
          : category.slug === "auto-service"
            ? autoServiceBannerImage
          : bannerImage,
      bannerUrl: `/${category.slug}/`,
      bannerCta: category.slug === "measuring-tools" ? "Смотреть товар" : "Смотреть раздел",
      items: getTabProducts(category.slug)
    };
  })
  .filter(Boolean);
---
<section class="section-top-pick-v02 section-best-sellers-construction flat-spacing flat-animate-tab">
  <div class="container">
    <div class="sect-heading type-2 has-col-right">
      <div class="wow fadeInUp">
        <h3 class="s-title">Хиты продаж</h3>
        <p class="s-desc text-body-1 cl-text-2">
          Популярные товары собраны по основным разделам каталога.
        </p>
      </div>

      <div class="col-right wow fadeInUp" data-wow-delay="0.1s">
        <ul class="tab-btn-wrap-v2 best-sellers-tabs" role="tablist">
          {tabs.map((tab, index) => (
            <li class="nav-tab-item" role="presentation">
              <a
                class={`tf-btn-tab ${index === 0 ? "active" : ""}`}
                data-bs-toggle="tab"
                href={`#top-pick-${tab.id}`}
                role="tab"
              >
                <span class="fw-semibold">{tab.label}</span>
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <div class="tab-content">
      {tabs.map((tab, index) => (
        <div class={`tab-pane ${index === 0 ? "active show" : ""}`} id={`top-pick-${tab.id}`} role="tabpanel">
          <div class="wrap-prd">
            <div class="col-prd-1">
              <div class="banner-image-text type-abs style-18 v2 mb-20 best-sellers-banner">
                <a class="bn-image img-style" href={tab.bannerUrl}>
                  <img
                    alt={tab.banner.title}
                    height="376"
                    loading="lazy"
                    sizes="(max-width: 767px) 100vw, 450px"
                    src={getImageVariant(tab.bannerImage, 450)}
                    srcset={getImageSrcset(tab.bannerImage, [360, 450, 540])}
                    width="552"
                  />
                </a>
                <div class="bn-content wow fadeInUp">
                  <a class="title text-white h3 fw-medium link mb-8" href={tab.bannerUrl}>{tab.banner.title}</a>
                  <p class="desc text-body-1 text-white mb-28">{tab.banner.desc}</p>
                  <a class="tf-btn btn-white hv-primary" href={tab.bannerUrl}>{tab.bannerCta}</a>
                </div>
              </div>

              <div class="tf-grid-layout tf-col-2 gap-20">
                {tab.items.slice(0, 2).map((product) => (
                  <ProductCard className="product-style_stroke wow fadeInUp" imageSizes={compactProductSizes} product={product} showMeta={false} />
                ))}
              </div>
            </div>

            <div class="col-prd-2">
              <div class="tf-grid-layout tf-col-2 lg-col-3 gap-20">
                {tab.items.slice(2, 8).map((product) => (
                  <ProductCard className="product-style_stroke wow fadeInUp" imageSizes={compactProductSizes} product={product} showMeta={false} />
                ))}
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .section-best-sellers-construction {
    background: var(--white);
  }

  .section-best-sellers-construction .sect-heading {
    margin-bottom: 40px;
  }

  .section-best-sellers-construction .sect-heading.has-col-right {
    align-items: flex-end;
    gap: 24px;
  }

  .section-best-sellers-construction .sect-heading.has-col-right > :first-child {
    flex: 1 1 420px;
    min-width: 0;
  }

  .section-best-sellers-construction .col-right {
    flex: 1 1 620px;
    margin-left: auto;
    overflow: visible;
  }

  .best-sellers-tabs {
    min-width: 0;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 12px 14px;
    justify-content: stretch;
  }

  .best-sellers-tabs .tf-btn-tab {
    width: 100%;
    min-height: 44px;
    white-space: normal;
    text-align: center;
  }

  .best-sellers-banner .bn-image img {
    object-fit: cover;
  }

  .best-sellers-banner,
  .best-sellers-banner .bn-image,
  .best-sellers-banner .bn-image img {
    height: 376px;
  }

  .best-sellers-banner .title {
    max-width: 360px;
  }

  .best-sellers-banner .desc {
    max-width: 360px;
  }

  :global(.section-best-sellers-construction .card-product_info .name-product) {
    display: -webkit-box;
    min-height: 48px;
    overflow: hidden;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
  }

  @media (max-width: 767px) {
    .section-best-sellers-construction .sect-heading {
      margin-bottom: 28px;
    }

    .section-best-sellers-construction .sect-heading.has-col-right {
      align-items: flex-start;
      gap: 20px;
    }

    .section-best-sellers-construction .col-right {
      width: 100%;
      margin-left: 0;
    }

    .best-sellers-tabs {
      gap: 10px;
    }

    .best-sellers-banner .title,
    .best-sellers-banner .desc {
      max-width: 280px;
    }
  }
</style>
