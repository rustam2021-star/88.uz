---
import ProductCard from "./ProductCard.astro";
import { getProductImage } from "../lib/catalog.js";
import categories from "../data/categories.json";
import products from "../data/products.json";

const tabs = categories
  .map((category) => ({
    id: category.slug,
    label: category.title,
    items: products.filter((product) => product.category_slug === category.slug).slice(0, 4)
  }))
  .filter((tab) => tab.items.length > 0)
  .slice(0, 5)
  .map((tab) => ({
    ...tab,
    image: getProductImage(tab.items[0])
  }));
---
<section class="section-best-seller-office flat-spacing flat-animate-tab">
  <div class="container">
    <div class="sect-heading text-center wow fadeInUp">
      <h3 class="s-title">Хиты продаж</h3>
      <p class="s-desc text-body-1 cl-text-2">Популярные товары собраны по основным разделам каталога.</p>
    </div>

    <div class="best-seller-office-layout">
      <ul class="tab-btn-wrap-v4 best-seller-category-tabs" role="tablist">
        {tabs.map((tab, index) => (
          <li class="nav-tab-item" role="presentation">
            <a class={`tf-btn-tab ${index === 0 ? "active" : ""}`} data-bs-toggle="tab" href={`#best-${tab.id}`} role="tab">
              <span class="img">
                <img alt={tab.label} height="56" loading="lazy" src={tab.image} width="56" />
              </span>
              <span class="best-seller-tab-text fw-medium">{tab.label}</span>
            </a>
          </li>
        ))}
      </ul>

      <div class="tab-content best-seller-products">
        {tabs.map((tab, index) => (
          <div class={`tab-pane ${index === 0 ? "active show" : ""}`} id={`best-${tab.id}`} role="tabpanel">
            <div class="best-seller-products-grid">
              {tab.items.map((product) => (
                <ProductCard className="best-seller-product-card wow fadeInUp" product={product} />
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .section-best-seller-office {
    background: var(--bg);
  }

  .section-best-seller-office .sect-heading {
    margin-bottom: 42px;
  }

  .best-seller-office-layout {
    display: grid;
    gap: 30px;
  }

  .best-seller-category-tabs {
    margin-bottom: 0;
    align-self: start;
    overflow: hidden;
  }

  .best-seller-category-tabs .nav-tab-item {
    min-width: 0;
  }

  .best-seller-category-tabs .tf-btn-tab {
    width: 100%;
    min-width: 0;
    box-sizing: border-box;
    padding: 12px;
    color: var(--text);
  }

  .tab-btn-wrap-v4.best-seller-category-tabs .tf-btn-tab .best-seller-tab-text {
    min-width: 0;
    flex: 1 1 auto;
    color: var(--text);
    font-size: 18px;
    line-height: 1.25;
    letter-spacing: 0;
    display: block;
    overflow: visible;
    white-space: normal;
    word-break: normal;
  }

  .best-seller-category-tabs .img {
    width: 56px;
    height: 56px;
    flex: 0 0 56px;
    display: grid;
    place-items: center;
    overflow: hidden;
  }

  .best-seller-category-tabs .img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 6px;
  }

  .best-seller-products {
    min-width: 0;
  }

  .best-seller-products-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 24px 16px;
  }

  .section-best-seller-office .card-product {
    min-width: 0;
  }

  .section-best-seller-office .card-product_wrapper {
    background: #f0f0f0;
    border-radius: 12px;
  }

  .section-best-seller-office .card-product_wrapper .product-img {
    height: 100%;
    display: block;
    background: #f0f0f0;
  }

  .section-best-seller-office .card-product_info .name-product {
    display: -webkit-box;
    min-height: 48px;
    overflow: hidden;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
  }

  @media (min-width: 768px) {
    .best-seller-products-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 30px;
    }
  }

  @media (min-width: 1200px) {
    .best-seller-office-layout {
      grid-template-columns: 326px minmax(0, 1fr);
    }

    .best-seller-products-grid {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }

    .best-seller-category-tabs .tf-btn-tab {
      padding: 10px 14px;
      min-height: 70px;
    }
  }

  @media (max-width: 1199px) {
    .best-seller-category-tabs {
      overflow-x: auto;
    }

    .tab-btn-wrap-v4.best-seller-category-tabs .tf-btn-tab .best-seller-tab-text {
      font-size: 16px;
      white-space: normal;
    }
  }

  @media (max-width: 575px) {
    .section-best-seller-office .sect-heading {
      margin-bottom: 28px;
    }

    .best-seller-products-grid {
      gap: 24px 10px;
    }

    .section-best-seller-office .card-product_info .name-product {
      min-height: 44px;
    }
  }
</style>
