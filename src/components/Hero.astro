---
import { productUrl, site, telegramOrderUrl } from "../lib/catalog";

const { product } = Astro.props;
---

<section class="home-hero" aria-labelledby="home-title">
  <div class="hero-panel tf-template-hero">
    <div>
      <p class="eyebrow">Полезные товары, которые выручают</p>
      <h1 id="home-title">Инструменты, гаджеты и полезные товары в Ташкенте</h1>
      <p>Практичные товары для дома, авто, ремонта и диагностики</p>
      <div class="actions">
        <a class="button button-primary" href="#products">Смотреть каталог</a>
        <a class="button button-telegram" href={product ? telegramOrderUrl(product) : site.telegram}>Заказать в Telegram</a>
      </div>
    </div>
    {product && (
      <a class="hero-media" href={productUrl(product)} aria-label={product.title}>
        <img src={product.main_image} alt={product.title} width="640" height="480" loading="eager" />
      </a>
    )}
  </div>
</section>
