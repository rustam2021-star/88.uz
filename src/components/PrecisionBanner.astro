---
import { getImageSrcset, getImageVariant } from "../lib/catalog.js";
import { getLocale, localePath } from "../i18n/index.js";

const locale = getLocale(Astro.url.pathname);
const slideTranslations = {
  ru: [
  {
    image: "/assets/theme/assets/images/slider/slider-34.jpg",
    eyebrow: "НАДЕЖНО ДЛЯ РАБОТЫ",
    title: "Приборы и оборудование для точных задач",
    description: "Подберите надежные измерительные приборы, детекторы и инструменты для ремонта, диагностики и ежедневной работы.",
    dark: false
  },
  {
    image: "/assets/theme/assets/images/slider/slider-35.jpg",
    eyebrow: "ТОЧНОСТЬ ПОД КОНТРОЛЕМ",
    title: "Измерительные приборы для профессионалов",
    description: "Мультиметры, влагомеры, pH-метры и тестеры помогают быстрее проверять параметры и работать увереннее.",
    dark: true
  },
  {
    image: "/assets/theme/assets/images/slider/slider-36-instruments.webp",
    eyebrow: "ТОЧНЫЕ ИЗМЕРЕНИЯ ДЛЯ ЛЮБЫХ ЗАДАЧ",
    title: "Профессиональные приборы для работы",
    description: "UTi320E, SNDWAY SW-50G, AR991, лазерный уровень и токовые клещи UNI-T UT202A — точность и надежность в одном разделе.",
    dark: true
  }],
  uz: [
    { image: "/assets/theme/assets/images/slider/slider-34.jpg", eyebrow: "ISH UCHUN ISHONCHLI", title: "Aniq vazifalar uchun asboblar va uskunalar", description: "Ta’mirlash, diagnostika va kundalik ishlar uchun ishonchli o‘lchash asboblari, detektorlar va vositalarni tanlang.", dark: false },
    { image: "/assets/theme/assets/images/slider/slider-35.jpg", eyebrow: "ANIQLIK NAZORAT OSTIDA", title: "Mutaxassislar uchun o‘lchash asboblari", description: "Multimetrlar, namlik o‘lchagichlar, pH metrlar va testerlar parametrlarni tezroq tekshirishga yordam beradi.", dark: true },
    { image: "/assets/theme/assets/images/slider/slider-36-instruments.webp", eyebrow: "HAR QANDAY VAZIFA UCHUN ANIQ O‘LCHOV", title: "Ish uchun professional asboblar", description: "UTi320E, SNDWAY SW-50G, AR991, lazer darajasi va UNI-T UT202A tok qisqichlari — bir bo‘limda aniqlik va ishonchlilik.", dark: true }
  ],
  en: [
    { image: "/assets/theme/assets/images/slider/slider-34.jpg", eyebrow: "RELIABLE FOR EVERY JOB", title: "Instruments and equipment for precise tasks", description: "Choose reliable measuring instruments, detectors and tools for repairs, diagnostics and everyday work.", dark: false },
    { image: "/assets/theme/assets/images/slider/slider-35.jpg", eyebrow: "PRECISION UNDER CONTROL", title: "Measuring instruments for professionals", description: "Multimeters, moisture meters, pH meters and testers help you check parameters faster and work confidently.", dark: true },
    { image: "/assets/theme/assets/images/slider/slider-36-instruments.webp", eyebrow: "ACCURATE MEASUREMENTS FOR EVERY TASK", title: "Professional instruments for work", description: "UTi320E, SNDWAY SW-50G, AR991, a laser level and UNI-T UT202A clamp meter — precision and reliability in one section.", dark: true }
  ]
};
const slides = slideTranslations[locale] || slideTranslations.ru;
const catalogLabel = locale === "en" ? "View catalog" : locale === "uz" ? "Katalogni ko‘rish" : "Смотреть каталог";
---
<section class="themesFlat construction-hero-section">
  <div class="container-full">
    <div
      class="swiper tf-swiper sw-slide-show slider_effect_fade construction-hero-swiper"
      data-auto="true"
      data-cursor="true"
      data-delay="3000"
      data-loop="true"
      data-mobile="1"
      data-preview="1"
      data-space="15"
      data-space-lg="30"
      data-space-md="20"
      data-tablet="1"
      dir="ltr"
    >
      <div class="swiper-wrapper">
        {slides.map((slide, index) => (
          <div class="swiper-slide">
            <div class="slider-wrap slideshow-wrap rounded-20 overflow-hidden construction-hero">
              <div class="sld_image">
                <img
                  alt={slide.title}
                  class="scale-item scale-item-1"
                  decoding="async"
                  fetchpriority={index === 0 ? "high" : "auto"}
                  height="680"
                  loading={index === 0 ? "eager" : "lazy"}
                  sizes="100vw"
                  src={getImageVariant(slide.image, 1200)}
                  srcset={getImageSrcset(slide.image, [768, 1200, 1770])}
                  width="1770"
                />
              </div>

              <div class="sld_content type-4">
                <div class="content-sld_wrap">
                  <h6 class={`mb-12 fade-item fade-item-1 ${slide.dark ? "text-white" : ""}`}>{slide.eyebrow}</h6>
                  {index === 0 ? (
                    <h1 class={`h1 mb-20 fade-item fade-item-2 title ${slide.dark ? "text-white" : ""}`}>{slide.title}</h1>
                  ) : (
                    <h2 class={`h1 mb-20 fade-item fade-item-2 title ${slide.dark ? "text-white" : ""}`}>{slide.title}</h2>
                  )}
                  <p class={`text-body-1 fade-item fade-item-3 mb-32 ${slide.dark ? "text-white" : ""}`}>
                    {slide.description}
                  </p>
                  <div class="fade-item fade-item-4">
                    <a class="tf-btn btn-white animate-btn animate-dark" href={localePath("/catalog/", locale)}>{catalogLabel}</a>
                  </div>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
      <div class="sw-line-default tf-sw-pagination"></div>
    </div>
  </div>
</section>

<style>
  .construction-hero-section {
    padding-top: 60px;
  }

  .construction-hero-swiper {
    cursor: grab;
  }

  .construction-hero-swiper:active {
    cursor: grabbing;
  }

  .construction-hero-swiper:not(.swiper-initialized) .swiper-slide:not(:first-child) {
    display: none;
  }

  .construction-hero-swiper:not(.swiper-initialized) .swiper-wrapper {
    transform: none !important;
  }

  .construction-hero {
    position: relative;
  }

  .construction-hero .sld_image img {
    width: 100%;
    min-height: 460px;
    aspect-ratio: 1770 / 680;
    object-fit: cover;
  }

  .construction-hero .title {
    display: block;
    color: var(--black);
    max-width: 520px;
  }

  .construction-hero .content-sld_wrap {
    max-width: 520px;
  }

  .construction-hero-swiper .tf-sw-pagination {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 28px;
    z-index: 3;
  }

  @media (max-width: 1199px) {
    .construction-hero-section {
      padding-top: 40px;
    }

    .construction-hero .sld_image img {
      min-height: 420px;
    }
  }

  @media (max-width: 767px) {
    .construction-hero-section {
      padding-top: 24px;
    }

    .construction-hero .sld_image img {
      min-height: 500px;
      object-position: 62% center;
    }

    .construction-hero .sld_content.type-4 {
      bottom: 56px;
      padding-right: 20px;
    }

    .construction-hero .title {
      max-width: 340px;
    }

    .construction-hero .text-body-1 {
      max-width: 330px;
    }
  }

  @media (max-width: 575px) {
    .construction-hero-section {
      padding-top: 16px;
    }

    .construction-hero .sld_image img {
      min-height: 480px;
      object-position: 68% center;
    }
  }
</style>
