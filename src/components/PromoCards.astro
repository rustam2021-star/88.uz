---
import { productUrl } from "../lib/catalog";

const { products = [] } = Astro.props;
const labels = ["Тепловизоры и мультиметры", "Автоинструменты", "Гаджеты для дома"];
---

<section class="promo-grid" aria-label="Популярные подборки">
  {products.map((product, index) => (
    <a class="promo-card tf-template-promo" href={productUrl(product)}>
      <div>
        <p class="eyebrow">{labels[index] ?? "Подборка"}</p>
        <h2>{product.title}</h2>
        <p>{product.short_description}</p>
      </div>
      <img src={product.main_image} alt={product.title} width="240" height="180" loading="lazy" />
    </a>
  ))}
</section>
