---
const { product, className = "wow fadeInUp" } = Astro.props;
const productUrl = `/product/${product.slug}/`;
const price = `$${Number(product.price).toFixed(2)}`;
const oldPrice = product.old_price ? `$${Number(product.old_price).toFixed(2)}` : "";
---
<div class={`card-product ${className}`}>
  <div class="card-product_wrapper square">
    <a class="product-img" href={productUrl}>
      <img alt="Товар" class="img-product" height="330" loading="lazy" src={product.main_image} width="330" />
      <img alt="Товар" class="img-hover" height="330" loading="lazy" src={product.hover_image || product.main_image} width="330" />
    </a>
    <ul class="product-action_list">
      <li class="wishlist">
        <a class="hover-tooltip tooltip-left box-icon" href="#;">
          <span class="icon icon-heart"></span>
          <span class="tooltip">В избранное</span>
        </a>
      </li>
      <li class="compare">
        <a class="hover-tooltip tooltip-left box-icon" href="#compare">
          <span class="icon icon-ArrowsLeftRight"></span>
          <span class="tooltip">Сравнить</span>
        </a>
      </li>
      <li>
        <a class="hover-tooltip tooltip-left box-icon" href={productUrl}>
          <span class="icon icon-Eye"></span>
          <span class="tooltip">Быстрый просмотр</span>
        </a>
      </li>
    </ul>
    {product.badges?.length > 0 && (
      <ul class="product-badge_list">
        {product.badges.map((badge) => <li class="product-badge_item text-caption-01 sale">{badge}</li>)}
      </ul>
    )}
    <div class="product-action_bot">
      <a class="tf-btn btn-white small w-100" href="#shoppingCart">В корзину</a>
    </div>
  </div>
  <div class="card-product_info">
    <a class="name-product lh-24 fw-medium link-underline-text" href={productUrl}>{product.title}</a>
    <div class="star-wrap d-flex align-items-center">
      <i class="icon icon-Star"></i>
      <i class="icon icon-Star"></i>
      <i class="icon icon-Star"></i>
      <i class="icon icon-Star"></i>
      <i class="icon icon-Star"></i>
    </div>
    <div class="price-wrap">
      <span class="price-new text-primary fw-semibold">{price}</span>
      {oldPrice && <span class="price-old text-caption-01 cl-text-3">{oldPrice}</span>}
    </div>
  </div>
</div>
