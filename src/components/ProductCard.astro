---
import { categoryUrl, formatPrice, getCategory, productUrl, site } from "../lib/catalog";

const { product, priority = false } = Astro.props;
const category = getCategory(product.category_slug);
---

<article class="product-card">
  <div class="product-media">
    <span class:list={["product-badge", product.in_stock ? "badge-ok" : "badge-wait"]}>
      {product.in_stock ? "В наличии" : "Под заказ"}
    </span>
    <a class="media-image-link" href={productUrl(product)} aria-label={product.title}>
      <img
        src={product.main_image}
        alt={product.title}
        loading={priority ? "eager" : "lazy"}
        width="640"
        height="480"
        onerror="this.remove()"
      />
      <span class="media-fallback">{product.brand}</span>
    </a>
    <div class="product-hover-actions" aria-label={`Быстрые действия для ${product.title}`}>
      <a class="hover-order" href={site.telegram}>Заказать</a>
      <a class="quick-view" href={productUrl(product)} aria-label={`Подробнее: ${product.title}`}>
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M7 17 17 7M9 7h8v8" />
        </svg>
      </a>
    </div>
  </div>
  <div class="product-body">
    {category && <a class="product-category" href={categoryUrl(category)}>{category.title}</a>}
    <h3><a href={productUrl(product)}>{product.title}</a></h3>
    <p>{product.short_description}</p>
    <div class="product-meta">
      <strong>{formatPrice(product)}</strong>
      <a class="card-link" href={product.in_stock ? productUrl(product) : site.telegram}>
        {product.in_stock ? "Подробнее" : "Уточнить"}
      </a>
    </div>
  </div>
</article>
