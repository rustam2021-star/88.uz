---
import BestSellerTabs from "../components/BestSellerTabs.astro";
import CategorySlider from "../components/CategorySlider.astro";
import HelpFaq from "../components/HelpFaq.astro";
import InsightsBlog from "../components/InsightsBlog.astro";
import MainLayout from "../layouts/MainLayout.astro";
import PrecisionBanner from "../components/PrecisionBanner.astro";
import ProductThumbs from "../components/ProductThumbs.astro";
import ServiceIcons from "../components/ServiceIcons.astro";
import Testimonials from "../components/Testimonials.astro";
import { getBreadcrumbItems, getHomeSeo, getPageSchema } from "../lib/seo.js";
import { getLocale } from "../i18n/index.js";

const locale = getLocale(Astro.url.pathname);
const seo = getHomeSeo(locale);
const breadcrumbs = getBreadcrumbItems([{ name: "Главная", url: "/" }]);
---
<MainLayout
  title={seo.title}
  description={seo.description}
  canonicalPath={seo.url}
  robots={seo.robots}
  jsonLd={getPageSchema({ seo, breadcrumbs })}
>
  <PrecisionBanner />
  <CategorySlider />
  <BestSellerTabs />
  <ProductThumbs />
  <Testimonials />
  <InsightsBlog />
  <HelpFaq />
  <ServiceIcons />
</MainLayout>
