---
import BestSellerTabs from "../components/BestSellerTabs.astro";
import CategorySlider from "../components/CategorySlider.astro";
import GearBundle from "../components/GearBundle.astro";
import HelpFaq from "../components/HelpFaq.astro";
import HomeBanners from "../components/HomeBanners.astro";
import InsightsBlog from "../components/InsightsBlog.astro";
import MainLayout from "../layouts/MainLayout.astro";
import PrecisionBanner from "../components/PrecisionBanner.astro";
import ProductThumbs from "../components/ProductThumbs.astro";
import ServiceIcons from "../components/ServiceIcons.astro";
import Testimonials from "../components/Testimonials.astro";

const title = "88.uz - измерительные приборы и оборудование";
const description =
  "88.uz - каталог измерительных приборов, детекторов, автоинструментов, электроники и оборудования в Ташкенте.";
---
<MainLayout title={title} description={description}>
  <PrecisionBanner />
  <CategorySlider />
  <BestSellerTabs />
  <ProductThumbs />
  <HomeBanners />
  <GearBundle />
  <Testimonials />
  <InsightsBlog />
  <HelpFaq />
  <ServiceIcons />
</MainLayout>
