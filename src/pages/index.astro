---
import ProductCard from "../components/ProductCard.astro";
import MainLayout from "../layouts/MainLayout.astro";
import { categoryUrl, getCategories, getProducts, productUrl, site, telegramOrderUrl } from "../lib/catalog";

const categories = getCategories();
const products = getProducts();
const featured = products.slice(0, 10);
const heroProduct = products.find((product) => product.slug === "teplovizor-uni-t-uti260b") ?? products[0];
const promoProducts = [
  products.find((product) => product.slug === "aneng-621a-multimetr"),
  products.find((product) => product.slug === "tolshchinomer-avtomobilnyy-kraski"),
  products.find((product) => product.slug === "robot-dlya-moyki-okon")
].filter(Boolean);
const categoryHighlights = categories
  .map((category) => ({
    category,
    count: products.filter((product) => product.category_slug === category.slug).length,
    product: products.find((product) => product.category_slug === category.slug)
  }))
  .filter((item) => item.count > 0)
  .slice(0, 8);
const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "Store",
  name: site.name,
  legalName: site.legalName,
  url: site.url,
  telephone: site.phone,
  address: {
    "@type": "PostalAddress",
    addressLocality: site.city,
    addressCountry: "UZ"
  }
};
---

<MainLayout
  title="88.uz — полезные товары, инструменты и гаджеты в Ташкенте"
  description="Практичные товары для дома, авто, ремонта и диагностики. Тепловизоры, мультиметры, дальномеры, толщиномеры, pH/TDS-метры и гаджеты с заказом через Telegram."
  canonical="/"
  schema={organizationSchema}
>
  <section class="category-showcase" id="categories" aria-label="Категории товаров">
    <div class="category-rail">
      {categories.slice(0, 12).map((category) => (
        <a class="category-pill" href={categoryUrl(category)}>{category.title}</a>
      ))}
      <a class="category-pill" href={site.telegram}>Распродажа</a>
    </div>
  </section>

  <section class="home-hero" aria-labelledby="home-title">
    <div class="hero-panel">
      <div>
        <p class="eyebrow">Полезные товары, которые выручают</p>
        <h1 id="home-title">Инструменты, гаджеты и полезные товары в Ташкенте</h1>
        <p>Практичные товары для дома, авто, ремонта и диагностики. Подберем прибор, подтвердим наличие и оформим заказ через Telegram.</p>
        <div class="actions">
          <a class="button button-primary" href="#products">Смотреть каталог</a>
          <a class="button button-telegram" href={telegramOrderUrl(heroProduct)}>Заказать в Telegram</a>
        </div>
      </div>
      <a class="hero-media" href={productUrl(heroProduct)} aria-label={heroProduct.title}>
        <img src={heroProduct.main_image} alt={heroProduct.title} width="640" height="480" loading="eager" />
      </a>
    </div>
  </section>

  <section class="promo-grid" aria-label="Популярные подборки">
    {promoProducts.map((product, index) => (
      <a class="promo-card" href={productUrl(product)}>
        <div>
          <p class="eyebrow">{index === 0 ? "Тепловизоры и мультиметры" : index === 1 ? "Автоинструменты" : "Гаджеты для дома"}</p>
          <h2>{product.title}</h2>
          <p>{product.short_description}</p>
        </div>
        <img src={product.main_image} alt={product.title} width="240" height="180" loading="lazy" />
      </a>
    ))}
  </section>

  <section class="benefits-row" aria-label="Преимущества 88.uz">
    <div class="benefit">Быстрая доставка</div>
    <div class="benefit">Проверенные товары</div>
    <div class="benefit">Помощь с выбором</div>
    <div class="benefit">Заказ через Telegram</div>
  </section>

  <section class="section" aria-labelledby="popular-categories-title">
    <div class="section-heading">
      <div>
        <p class="eyebrow">Каталог</p>
        <h2 id="popular-categories-title">Популярные категории</h2>
      </div>
    </div>
    <div class="category-grid">
      {categoryHighlights.map(({ category, product, count }) => (
        <a class="category-card" href={categoryUrl(category)}>
          {product && <img src={product.main_image} alt="" width="220" height="150" loading="lazy" />}
          <h3>{category.title}</h3>
          <p>{count} товаров · Ташкент</p>
        </a>
      ))}
    </div>
  </section>

  <section class="section" id="products" aria-labelledby="products-title">
    <div class="section-heading">
      <div>
        <p class="eyebrow">Витрина</p>
        <h2 id="products-title">Популярные товары</h2>
      </div>
      <a class="button button-secondary" href={site.telegram}>Уточнить наличие</a>
    </div>
    <div class="grid">
      {featured.map((product, index) => (
        <ProductCard product={product} priority={index < 4} />
      ))}
    </div>
  </section>

  <section class="content-band">
    <div class="info-card">
      <p class="eyebrow">SEO каталог</p>
      <h2>88.uz — статический каталог полезных товаров в Ташкенте</h2>
      <p>
        В каталоге 88.uz собраны измерительные приборы, автоинструменты, электроника, гаджеты и товары для дома.
        Основной сценарий простой: покупатель выбирает товар, пишет в Telegram или звонит, после чего мы подтверждаем наличие,
        характеристики и доставку по Ташкенту.
      </p>
    </div>
    <div class="info-card">
      <p class="eyebrow">Как заказать</p>
      <h2>Без корзины и оплаты на сайте</h2>
      <p>
        MVP не использует личные кабинеты, онлайн-оплату и backend. Основной контент отдается статическим HTML,
        а заявки идут через Telegram и телефон.
      </p>
      <div class="actions">
        <a class="button button-telegram" href={site.telegram}>Написать в Telegram</a>
        <a class="button button-secondary" href={`tel:${site.phone.replaceAll(" ", "")}`}>Позвонить</a>
      </div>
    </div>
  </section>
</MainLayout>
