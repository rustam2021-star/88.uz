---
import MainLayout from "../../layouts/MainLayout.astro";
import { basePosts, getLocalizedPosts, getLocalizedProducts } from "../../lib/content.js";
import { getLocale } from "../../i18n/index.js";
import { getPostImage, getPostUrl } from "../../lib/blog.js";
import { getImageSrcset, getImageVariant } from "../../lib/catalog.js";
import SeoBreadcrumbs from "../../components/SeoBreadcrumbs.astro";
import { getBlogPostSeo, getBreadcrumbItems, getPageSchema } from "../../lib/seo.js";

export function getStaticPaths() {
  return basePosts.map((post) => ({
    params: { slug: post.slug },
    props: { post }
  }));
}

const locale = getLocale(Astro.url.pathname);
const posts = getLocalizedPosts(locale);
const products = getLocalizedProducts(locale);
const post = posts.find((item) => item.slug === Astro.props.post.slug) || Astro.props.post;
const relatedPosts = posts.filter((item) => item.slug !== post.slug).slice(0, 3);
const seo = getBlogPostSeo(post, locale);
const breadcrumbs = getBreadcrumbItems([
  { name: "Главная", url: "/" },
  { name: "Блог", url: "/blog/" },
  { name: post.title, url: seo.url }
]);
---
<MainLayout
  title={seo.title}
  description={seo.description}
  canonicalPath={seo.url}
  robots={seo.robots}
  ogImage={getPostImage(post, products)}
  ogType="article"
  jsonLd={getPageSchema({ seo, breadcrumbs })}
>
  <section class="section-page-title text-center flat-spacing-2 pb-0">
    <div class="container">
      <div class="main-page-title">
        <SeoBreadcrumbs items={breadcrumbs} />
        <h1 class="h3">{post.title}</h1>
        <p class="text-body-1 cl-text-2">{post.excerpt}</p>
      </div>
    </div>
  </section>

  <section class="flat-spacing">
    <div class="container">
      <article class="main-blog-single">
        <div class="blog-image">
          <img
            alt={post.title}
            height="680"
            loading="lazy"
            sizes="(max-width: 767px) 100vw, 900px"
            src={getImageVariant(getPostImage(post, products), 705)}
            srcset={getImageSrcset(getPostImage(post, products), [440, 705])}
            width="1410"
          />
        </div>
        <div class="blog-content">
          <div class="blog-heading">
            <span class="entry-tag">{post.category}</span>
            <div class="entry-meta">
              <span class="meta-item"><i class="icon icon-CalendarBlank"></i>{post.date}</span>
              <span class="meta-item"><i class="icon icon-User"></i>88.uz</span>
            </div>
          </div>
          {post.content.map((paragraph) => <p class="text-body-1 cl-text-2">{paragraph}</p>)}
        </div>
      </article>
    </div>
  </section>

  <section class="flat-spacing pt-0">
    <div class="container">
      <div class="sect-heading text-center">
        <h3 class="s-title">Еще статьи</h3>
      </div>
      <div class="tf-grid-layout sm-col-2 lg-col-3">
        {relatedPosts.map((item) => (
          <article class="article-blog hover-img">
            <a class="blog-image img-style" href={getPostUrl(item)}>
              <img
                alt={item.title}
                height="280"
                loading="lazy"
                sizes="(max-width: 575px) 100vw, (max-width: 991px) 45vw, 330px"
                src={getImageVariant(getPostImage(item, products), 330)}
                srcset={getImageSrcset(getPostImage(item, products), [220, 330, 440, 705])}
                width="450"
              />
            </a>
            <div class="blog-content">
              <p class="entry-date text-caption-01 fw-semibold cl-text-3">{item.date}</p>
              <h5 class="entry-title"><a class="link-underline link" href={getPostUrl(item)}>{item.title}</a></h5>
              <p class="entry-desc cl-text-2">{item.excerpt}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>
</MainLayout>
