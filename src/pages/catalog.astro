---
import MainLayout from "../layouts/MainLayout.astro";
import ProductCard from "../components/ProductCard.astro";
import categories from "../data/categories.json";
import products from "../data/products.json";
import SeoBreadcrumbs from "../components/SeoBreadcrumbs.astro";
import { getBreadcrumbItems, getCatalogSeo, getCollectionSchema, getPageSchema } from "../lib/seo.js";

const seo = getCatalogSeo();
const breadcrumbs = getBreadcrumbItems([{ name: "Главная", url: "/" }, { name: "Каталог", url: "/catalog/" }]);
---
<MainLayout
  title={seo.title}
  description={seo.description}
  canonicalPath={seo.url}
  robots={seo.robots}
  jsonLd={getPageSchema({ seo, breadcrumbs, pageSchema: getCollectionSchema({ name: seo.h1, url: seo.url, products }) })}
>
  <section class="section-page-title text-center flat-spacing-2 pb-0">
    <div class="container">
      <div class="main-page-title">
        <SeoBreadcrumbs items={breadcrumbs} />
        <h1 class="h3">Каталог товаров</h1>
        <p class="text-body-1 cl-text-2">
          Подборка товаров из профиля продавца: измерительные приборы, детекторы, автоинструменты,
          электроника, оборудование и товары для ухода.
        </p>
      </div>
    </div>
  </section>

  <section class="flat-spacing">
    <div class="container">
      <div class="tf-shop-control sticky-top no-offset">
        <a class="tf-btn-filter" data-bs-toggle="offcanvas" href="#filterShop">
          <span class="icon icon-filter"></span>
          <span class="text">Показать категории</span>
        </a>
        <div class="tf-control-sorting">
          <div class="tf-dropdown-sort">
            <div class="btn-select">
              <span class="text-sort-value" data-search-count>{products.length} товаров</span>
            </div>
          </div>
        </div>
      </div>

      <div class="tf-grid-layout tf-col-2 lg-col-4">
        {products.map((product) => <ProductCard product={product} />)}
      </div>
      <p class="text-center flat-spacing" data-search-empty hidden></p>
    </div>
  </section>

  <div class="offcanvas offcanvas-start canvas-filter" id="filterShop">
    <div class="canvas-wrapper">
      <div class="canvas-header">
        <h5>Категории</h5>
        <span class="icon-close-popup" data-bs-dismiss="offcanvas"><i class="icon icon-X2"></i></span>
      </div>
      <div class="canvas-body">
        <div class="widget-facet">
          <h6>Разделы каталога</h6>
          <ul class="list-categoris current-scrollbar">
            {categories.map((category) => (
              <li class="cate-item">
                <a href={`/${category.slug}/`}><span>{category.title}</span></a>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </div>

  <script>
    const query = new URLSearchParams(window.location.search).get("q")?.trim().toLocaleLowerCase("ru-RU") || "";
    const cards = [...document.querySelectorAll("[data-product-search]")];
    const count = document.querySelector("[data-search-count]");
    const empty = document.querySelector("[data-search-empty]");
    const visibleCards = cards.filter((card) => !query || card.dataset.productSearch?.includes(query));

    cards.forEach((card) => { card.hidden = !visibleCards.includes(card); });
    if (count) count.textContent = query ? `Найдено: ${visibleCards.length}` : `${cards.length} товаров`;
    if (empty && visibleCards.length === 0) {
      empty.hidden = false;
      empty.textContent = `По запросу «${query}» ничего не найдено.`;
    }
  </script>
</MainLayout>
