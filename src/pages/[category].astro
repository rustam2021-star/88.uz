---
import Breadcrumbs from "../components/Breadcrumbs.astro";
import ProductCard from "../components/ProductCard.astro";
import MainLayout from "../layouts/MainLayout.astro";
import {
  buildBreadcrumbSchema,
  buildCollectionSchema,
  categoryUrl,
  getCategories,
  getProductsByCategory,
  site
} from "../lib/catalog";

export function getStaticPaths() {
  return getCategories().map((category) => ({
    params: { category: category.slug },
    props: { category }
  }));
}

const { category } = Astro.props;
const products = getProductsByCategory(category.slug);
const breadcrumbs = [
  { name: "Главная", href: "/" },
  { name: category.title, href: categoryUrl(category) }
];
const schema = [buildBreadcrumbSchema(breadcrumbs), buildCollectionSchema(category, products)];
---

<MainLayout
  title={category.seo_title}
  description={category.seo_description}
  canonical={categoryUrl(category)}
  schema={schema}
>
  <section class="page-title">
    <Breadcrumbs items={breadcrumbs} />
    <p class="eyebrow">Категория 88.uz</p>
    <h1>{category.h1}</h1>
    <p>{category.description_top}</p>
    <div class="chips">
      <span class="chip">{products.length} товаров</span>
      <span class="chip">Ташкент</span>
      <span class="chip">Заказ через Telegram</span>
      <span class="chip">Доставка сейчас по Ташкенту</span>
    </div>
  </section>

  <section class="section" aria-labelledby="category-products-title">
    <div class="section-heading">
      <div>
        <p class="eyebrow">Товары</p>
        <h2 id="category-products-title">{category.title}</h2>
      </div>
      <a class="button button-secondary" href={site.telegram}>Заказать доставку</a>
    </div>
    {products.length > 0 ? (
      <div class="grid">
        {products.map((product, index) => (
          <ProductCard product={product} priority={index < 4} />
        ))}
      </div>
    ) : (
      <div class="contact-panel">
        <h2>Товары скоро появятся</h2>
        <p>Раздел уже готов под SEO и каталог. Добавьте товары в products.json.</p>
      </div>
    )}
  </section>

  <section class="content-band">
    <div class="info-card text-content">
      <p class="eyebrow">Как выбрать</p>
      <h2>Что важно в этом разделе</h2>
      <p>{category.description_bottom}</p>
    </div>
    {category.faq?.length > 0 && (
      <div class="faq-list" aria-label="FAQ">
        {category.faq.map((item) => (
          <article class="faq-item">
            <h2>{item.question}</h2>
            <p>{item.answer}</p>
          </article>
        ))}
      </div>
    )}
  </section>
</MainLayout>
