---
import Breadcrumbs from "../components/Breadcrumbs.astro";
import ProductCard from "../components/ProductCard.astro";
import MainLayout from "../layouts/MainLayout.astro";
import {
  buildBreadcrumbSchema,
  buildCollectionSchema,
  categoryUrl,
  getCategories,
  getProductsByCategory,
  site
} from "../lib/catalog";

export function getStaticPaths() {
  return getCategories().map((category) => ({
    params: { category: category.slug },
    props: { category }
  }));
}

const { category } = Astro.props;
const categories = getCategories();
const products = getProductsByCategory(category.slug);
const breadcrumbs = [
  { name: "Главная", href: "/" },
  { name: category.title, href: categoryUrl(category) }
];
const schema = [buildBreadcrumbSchema(breadcrumbs), buildCollectionSchema(category, products)];
---

<MainLayout
  title={category.seo_title}
  description={category.seo_description}
  canonical={categoryUrl(category)}
  schema={schema}
>
  <section class="page-title">
    <Breadcrumbs items={breadcrumbs} />
    <p class="eyebrow">Категория 88.uz</p>
    <h1>{category.h1}</h1>
    <p>{category.description_top}</p>
    <div class="chips">
      {categories.slice(0, 8).map((item) => (
        <a class="chip" href={categoryUrl(item)}>{item.title}</a>
      ))}
    </div>
  </section>

  <section class="section" aria-labelledby="category-products-title">
    <div class="filter-actions">
      <button class="filter-chip" type="button" data-filter-open>Фильтры</button>
      <a class="filter-chip" href="#category-products-title">Сортировка</a>
    </div>
    <div class="category-layout">
      <aside class="filter-card" aria-label="Фильтры каталога">
        <h2>Фильтры</h2>
        <span class="chip">{products.length} товаров</span>
        <span class="chip">В наличии</span>
        <span class="chip">Ташкент</span>
        <span class="chip">Заказ через Telegram</span>
        <button class="button button-primary" type="button" data-filter-close>Показать товары</button>
      </aside>

      <div>
        <div class="section-heading">
          <div>
            <p class="eyebrow">Товары</p>
            <h2 id="category-products-title">{category.title}</h2>
          </div>
          <a class="button button-secondary" href={site.telegram}>Заказать подбор</a>
        </div>
        {products.length > 0 ? (
          <div class="grid">
            {products.map((product, index) => (
              <ProductCard product={product} priority={index < 4} />
            ))}
          </div>
        ) : (
          <div class="contact-panel">
            <h2>Товары скоро появятся</h2>
            <p>Раздел уже готов под SEO. Напишите в Telegram, если нужен товар из этой категории.</p>
          </div>
        )}
      </div>
    </div>
  </section>

  <section class="content-band">
    <div class="info-card">
      <p class="eyebrow">Как выбрать</p>
      <h2>Что важно в этом разделе</h2>
      <p>{category.description_bottom}</p>
    </div>
    {category.faq?.length > 0 && (
      <div class="faq-list" aria-label="FAQ">
        {category.faq.map((item) => (
          <details class="faq-item">
            <summary>{item.question}</summary>
            <p>{item.answer}</p>
          </details>
        ))}
      </div>
    )}
  </section>

  <script>
    const filterOpen = document.querySelector("[data-filter-open]");
    const filterClose = document.querySelector("[data-filter-close]");
    filterOpen?.addEventListener("click", () => document.body.classList.add("filter-sheet-open"));
    filterClose?.addEventListener("click", () => document.body.classList.remove("filter-sheet-open"));
    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape") document.body.classList.remove("filter-sheet-open");
    });
  </script>
</MainLayout>
