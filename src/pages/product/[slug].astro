---
import MainLayout from "../../layouts/MainLayout.astro";
import ProductDetail from "../../components/ProductDetail.astro";
import products from "../../data/products.json";
import categories from "../../data/categories.json";
import { getBreadcrumbItems, getPageSchema, getProductSchema, getProductSeo } from "../../lib/seo.js";

export function getStaticPaths() {
  return products.map((product) => ({
    params: { slug: product.slug },
    props: { product }
  }));
}

const { product } = Astro.props;
const category = categories.find((item) => item.slug === product.category_slug) ?? categories[0];
const relatedProducts = products.filter((item) => product.related_products?.includes(item.slug));
const recentlyProducts = products.filter((item) => item.slug !== product.slug).slice(0, 4);
const seo = getProductSeo(product, category);
const breadcrumbs = getBreadcrumbItems([
  { name: "Главная", url: "/" },
  { name: "Каталог", url: "/catalog/" },
  { name: category.title, url: `/${category.slug}/` },
  { name: product.title, url: seo.url }
]);
---
<MainLayout
  title={seo.title}
  description={seo.description}
  canonicalPath={seo.url}
  robots={seo.robots}
  ogImage={product.main_image}
  ogType="product"
  jsonLd={getPageSchema({ seo, breadcrumbs, pageSchema: getProductSchema(product, category) })}
  productAssets={true}
>
  <ProductDetail
    product={product}
    category={category}
    breadcrumbs={breadcrumbs}
    relatedProducts={relatedProducts}
    recentlyProducts={recentlyProducts}
  />
</MainLayout>
