---
import MainLayout from "../../layouts/MainLayout.astro";
import ProductDetail from "../../components/ProductDetail.astro";
import { baseProducts, getLocalizedCategories, getLocalizedProducts } from "../../lib/content.js";
import { getLocale } from "../../i18n/index.js";
import { getBreadcrumbItems, getPageSchema, getProductSchema, getProductSeo } from "../../lib/seo.js";

export function getStaticPaths() {
  return baseProducts.map((product) => ({
    params: { slug: product.slug },
    props: { product }
  }));
}

const locale = getLocale(Astro.url.pathname);
const products = getLocalizedProducts(locale);
const categories = getLocalizedCategories(locale);
const product = products.find((item) => item.slug === Astro.props.product.slug) || Astro.props.product;
const category = categories.find((item) => item.slug === product.category_slug) ?? categories[0];
const categoryProducts = products.filter((item) => item.category_slug === product.category_slug && item.slug !== product.slug);
const manualRelated = products.filter((item) => product.related_products?.includes(item.slug) && item.slug !== product.slug);
const relatedProducts = [...manualRelated, ...categoryProducts]
  .filter((item, index, items) => items.findIndex((candidate) => candidate.slug === item.slug) === index)
  .sort((left, right) => Number(right.brand === product.brand) - Number(left.brand === product.brand))
  .slice(0, 8);
const navigationProducts = products.filter((item) => item.category_slug === product.category_slug);
const navigationIndex = navigationProducts.findIndex((item) => item.slug === product.slug);
const previousProduct = navigationProducts[(navigationIndex - 1 + navigationProducts.length) % navigationProducts.length];
const nextProduct = navigationProducts[(navigationIndex + 1) % navigationProducts.length];
const seo = getProductSeo(product, category, locale);
const breadcrumbs = getBreadcrumbItems([
  { name: "Главная", url: "/" },
  { name: "Каталог", url: "/catalog/" },
  { name: category.title, url: `/${category.slug}/` },
  { name: product.title, url: seo.url }
]);
---
<MainLayout
  title={seo.title}
  description={seo.description}
  canonicalPath={seo.url}
  robots={seo.robots}
  ogImage={product.main_image}
  ogType="product"
  jsonLd={getPageSchema({ seo, breadcrumbs, pageSchema: getProductSchema(product, category, locale) })}
  productAssets={true}
>
  <ProductDetail
    locale={locale}
    product={product}
    category={category}
    breadcrumbs={breadcrumbs}
    relatedProducts={relatedProducts}
    previousProduct={previousProduct}
    nextProduct={nextProduct}
  />
</MainLayout>
