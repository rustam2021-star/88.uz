---
import MainLayout from "../../layouts/MainLayout.astro";
import ProductDetail from "../../components/ProductDetail.astro";
import products from "../../data/products.json";
import categories from "../../data/categories.json";

export function getStaticPaths() {
  return products.map((product) => ({
    params: { slug: product.slug },
    props: { product }
  }));
}

const { product } = Astro.props;
const category = categories.find((item) => item.slug === product.category_slug) ?? categories[0];
const relatedProducts = products.filter((item) => product.related_products?.includes(item.slug));
const recentlyProducts = products.filter((item) => item.slug !== product.slug).slice(0, 4);
---
<MainLayout title={product.seo_title} description={product.seo_description} productAssets={true}>
  <ProductDetail product={product} category={category} relatedProducts={relatedProducts} recentlyProducts={recentlyProducts} />
</MainLayout>
